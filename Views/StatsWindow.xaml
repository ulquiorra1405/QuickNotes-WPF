<Window x:Class="QuickNotes.Views.StatsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Width="500" Height="600"
        ResizeMode="CanResize"
        MinWidth="400" MinHeight="400"
        Title="Estadísticas"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>

        <Style x:Key="StatValue" TargetType="TextBlock">
            <Setter Property="FontSize" Value="24"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>

        <Style x:Key="StatLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Opacity" Value="0.6"/>
        </Style>
    </Window.Resources>

    <Border x:Name="rootBorder" CornerRadius="10" Padding="4">
        <Border.Effect>
            <DropShadowEffect BlurRadius="16" ShadowDepth="4" Color="Black" Opacity="0.5"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Border x:Name="titleBar" Height="36" CornerRadius="8,8,0,0"
                    MouseDown="TitleBar_MouseDown" Padding="12,0">
                <Grid>
                    <TextBlock Text="📊 Estadísticas" FontSize="14" FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                    <Button x:Name="closeBtn" Content="✕" FontSize="12" Width="28" Height="24"
                            HorizontalAlignment="Right" VerticalAlignment="Center"
                            Cursor="Hand" Background="Transparent" BorderThickness="0"
                            Click="CloseBtn_Click"/>
                </Grid>
            </Border>

            <!-- Scrollable content -->
            <ScrollViewer x:Name="scrollViewer" Grid.Row="1" Padding="16,8,16,16"
                          VerticalScrollBarVisibility="Auto">
                <StackPanel x:Name="contentPanel">
                    <!-- Section 1: Summary -->
                    <TextBlock Text="Resumen" Style="{StaticResource SectionTitle}"/>
                    <Border x:Name="summaryBox" CornerRadius="8" Padding="14" Margin="0,0,0,16">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                                <TextBlock x:Name="totalNotesValue" Text="—" Style="{StaticResource StatValue}"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="Notas" Style="{StaticResource StatLabel}"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                                <TextBlock x:Name="totalWordsValue" Text="—" Style="{StaticResource StatValue}"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="Palabras" Style="{StaticResource StatLabel}"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                                <TextBlock x:Name="avgWordsValue" Text="—" Style="{StaticResource StatValue}"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="Promedio/nota" Style="{StaticResource StatLabel}"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Grid.Column="3" HorizontalAlignment="Center">
                                <TextBlock x:Name="longestValue" Text="—" Style="{StaticResource StatValue}"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="Nota + larga" Style="{StaticResource StatLabel}"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Section 2: Streak -->
                    <TextBlock Text="Racha de escritura" Style="{StaticResource SectionTitle}"/>
                    <Border x:Name="streakBox" CornerRadius="8" Padding="14" Margin="0,0,0,16">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock x:Name="currentStreakValue" Text="—" FontSize="32" FontWeight="Bold"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="días consecutivos" FontSize="11" Opacity="0.6"
                                           HorizontalAlignment="Center"/>
                                <TextBlock x:Name="currentStreakLabel" Text="Racha actual 🔥" FontSize="11"
                                           Foreground="#FF9800" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                                <TextBlock x:Name="bestStreakValue" Text="—" FontSize="32" FontWeight="Bold"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="días" FontSize="11" Opacity="0.6"
                                           HorizontalAlignment="Center"/>
                                <TextBlock x:Name="bestStreakLabel" Text="Mejor racha 🏆" FontSize="11"
                                           Opacity="0.7" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Section 3: Activity Calendar (GitHub-style) -->
                    <TextBlock Text="Calendario de actividad" Style="{StaticResource SectionTitle}"/>
                    <Border x:Name="calendarBox" CornerRadius="8" Padding="14" Margin="0,0,0,16">
                        <StackPanel>
                            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                                <StackPanel Orientation="Horizontal" x:Name="calendarPanel"/>
                            </ScrollViewer>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,6,0,0">
                                <TextBlock Text="Menos" FontSize="10" Opacity="0.5" VerticalAlignment="Center"/>
                                <Rectangle x:Name="c0" Width="10" Height="10" Margin="3,0" RadiusX="2" RadiusY="2"/>
                                <Rectangle x:Name="c1" Width="10" Height="10" Margin="3,0" RadiusX="2" RadiusY="2"/>
                                <Rectangle x:Name="c2" Width="10" Height="10" Margin="3,0" RadiusX="2" RadiusY="2"/>
                                <Rectangle x:Name="c3" Width="10" Height="10" Margin="3,0" RadiusX="2" RadiusY="2"/>
                                <Rectangle x:Name="c4" Width="10" Height="10" Margin="3,0" RadiusX="2" RadiusY="2"/>
                                <TextBlock Text="Más" FontSize="10" Opacity="0.5" VerticalAlignment="Center" Margin="3,0,0,0"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Section 4: Words per day (last 7) -->
                    <TextBlock Text="Últimos 7 días" Style="{StaticResource SectionTitle}"/>
                    <Border x:Name="weekBox" CornerRadius="8" Padding="14" Margin="0,0,0,16">
                        <StackPanel x:Name="weekPanel"/>
                    </Border>

                    <!-- Section 5: Top words -->
                    <TextBlock Text="Palabras más usadas" Style="{StaticResource SectionTitle}"/>
                    <Border x:Name="topWordsBox" CornerRadius="8" Padding="14" Margin="0,0,0,8">
                        <StackPanel x:Name="topWordsPanel"/>
                    </Border>

                    <!-- Empty state -->
                    <Border x:Name="emptyBox" CornerRadius="8" Padding="24" Margin="0,20,0,0"
                            Visibility="Collapsed">
                        <TextBlock Text="Aún no hay datos. ¡Empieza a escribir!" FontSize="14"
                                   HorizontalAlignment="Center" Opacity="0.5"/>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Border>
</Window>
