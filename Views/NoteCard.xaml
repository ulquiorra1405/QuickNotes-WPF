<UserControl x:Class="QuickNotes.Views.NoteCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:QuickNotes.Views"
             mc:Ignorable="d" 
             d:DesignHeight="200" d:DesignWidth="380"
             x:Name="cardRoot"
             AllowDrop="True"
             Loaded="Card_Loaded">
    <UserControl.Style>
        <Style TargetType="UserControl">
            <Setter Property="Opacity" Value="1"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsSearchMatch}" Value="False">
                    <Setter Property="Opacity" Value="0.4"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Style>

    <Border x:Name="mainBorder"
            Style="{DynamicResource NoteCard}"
            Background="{Binding Color}"
            BorderBrush="#30FFFFFF" BorderThickness="1"
            AllowDrop="True"
            ContextMenuOpening="MainBorder_ContextMenuOpening">
        <Border.ContextMenu>
            <ContextMenu Background="#2A2A2A" Foreground="#CCFFFFFF"
                         BorderBrush="#40FFFFFF" BorderThickness="1"
                         FontSize="13"
                         HasDropShadow="False">

                <!-- ContextMenu template: rounded corners, no shadow chrome -->
                <ContextMenu.Template>
                    <ControlTemplate TargetType="ContextMenu">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                Padding="4">
                            <ScrollViewer Style="{x:Null}" Padding="0" Margin="0"
                                          HorizontalScrollBarVisibility="Hidden"
                                          VerticalScrollBarVisibility="Auto"
                                          HorizontalContentAlignment="Stretch">
                                <ItemsPresenter Margin="0" HorizontalAlignment="Stretch"/>
                            </ScrollViewer>
                        </Border>
                    </ControlTemplate>
                </ContextMenu.Template>

                <ContextMenu.Resources>
                    <Style TargetType="MenuItem">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Foreground" Value="#CCFFFFFF"/>
                        <Setter Property="FontSize" Value="13"/>
                        <Setter Property="Height" Value="30"/>
                        <Setter Property="Padding" Value="10,0"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="MenuItem">
                                    <Border x:Name="bg"
                                            Background="{TemplateBinding Background}"
                                            CornerRadius="4"
                                            Padding="{TemplateBinding Padding}"
                                            SnapsToDevicePixels="True"
                                            HorizontalAlignment="Stretch">
                                        <ContentPresenter ContentSource="Header"
                                                          RecognizesAccessKey="False"
                                                          HorizontalAlignment="Left"
                                                          VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsHighlighted" Value="True">
                                            <Setter TargetName="bg" Property="Background" Value="#3FFFFFFF"/>
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter TargetName="bg" Property="Background" Value="#6FFFFFFF"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ContextMenu.Resources>
                <MenuItem Header="Duplicar" Tag="Duplicate" Click="ContextMenuItem_Click"/>
                <MenuItem Header="Eliminar" Tag="Delete" Click="ContextMenuItem_Click"/>
                <MenuItem Header="Archivar" Tag="Archive" Click="ContextMenuItem_Click"/>
                <MenuItem Header="Restaurar" Tag="Restore" Click="ContextMenuItem_Click"/>
                <MenuItem Header="Anclar" Tag="Pin" Click="ContextMenuItem_Click"/>
                <Separator x:Name="sep1" Background="#40FFFFFF"/>
                <MenuItem x:Name="notebookSubmenu" Header="Mover a libreta" Tag="NotebookSubmenu" Click="ContextMenuItem_Click"/>
                <MenuItem x:Name="tagsSubmenu" Header="Asignar tag" Tag="TagsSubmenu" Click="ContextMenuItem_Click"/>
                <Separator x:Name="sep2" Background="#40FFFFFF"/>
                <MenuItem Header="Exportar" Tag="Export" Click="ContextMenuItem_Click"/>
            </ContextMenu>
        </Border.ContextMenu>
        <Grid AllowDrop="True">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*" MaxHeight="95"/>
                <RowDefinition Height="36"/>
            </Grid.RowDefinitions>

            <!-- Search highlight bar -->
            <Rectangle Grid.RowSpan="2"
                       HorizontalAlignment="Left" Width="4"
                       VerticalAlignment="Stretch"
                       Fill="#80FFFFFF"
                       RadiusX="2" RadiusY="2"
                       Margin="2,4,0,4"
                       Visibility="Collapsed">
                <Rectangle.Style>
                    <Style TargetType="Rectangle">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsSearchMatch}" Value="True">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Rectangle.Style>
            </Rectangle>

            <!-- Title with dash -->
            <Grid Grid.Row="0" Margin="6,6,3,0" AllowDrop="True">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Width="16" Height="18"
                        Background="Transparent" Cursor="Hand"
                        BorderThickness="0"
                        VerticalAlignment="Center"
                        Padding="0"
                        Click="PinIndicator_Click">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Foreground" Value="{Binding TextForeground}"/>
                            <Setter Property="FontSize" Value="13"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="bg"
                                                Background="{TemplateBinding Background}"
                                                BorderThickness="0"
                                                CornerRadius="3"
                                                Padding="0">
                                            <Grid>
                                                <TextBlock x:Name="dashText" Text="-"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           Foreground="{TemplateBinding Foreground}"
                                                           FontSize="{TemplateBinding FontSize}"/>
                                                <TextBlock x:Name="pinHoverText" Text="📌"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           Foreground="{TemplateBinding Foreground}"
                                                           FontSize="{TemplateBinding FontSize}"
                                                           Opacity="0"/>
                                                <TextBlock x:Name="pinText" Text="📍"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           Foreground="{TemplateBinding Foreground}"
                                                           FontSize="{TemplateBinding FontSize}"
                                                           Opacity="0"/>
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="bg" Property="Background" Value="#20000000"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
                <Ellipse Grid.Column="1" Width="6" Height="6" Fill="#FF4444"
                         VerticalAlignment="Center" Margin="0,2,4,2"
                         IsHitTestVisible="False">
                    <Ellipse.Style>
                        <Style TargetType="Ellipse">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsDirty}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Ellipse.Style>
                </Ellipse>
                <TextBox Grid.Column="2" Style="{DynamicResource TitleBox}"
                         Foreground="{Binding TextForeground}"
                         Padding="0,2,0,2"
                         Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}"
                         TextChanged="Title_TextChanged"/>
                <TextBlock Grid.Column="3"
                           Text="{Binding LastModifiedDisplay}"
                           Foreground="{Binding TextForeground}" Opacity="0.53"
                           FontSize="10" VerticalAlignment="Center"
                           Margin="0,0,4,0"
                           IsHitTestVisible="False"/>
            </Grid>

            <!-- Separator -->
            <Rectangle Grid.Row="0" Fill="#20000000" Height="1"
                       Margin="12,0,3,0" VerticalAlignment="Bottom"/>

            <!-- Body -->
            <TextBlock Grid.Row="1"
                       x:Name="cardBodyBlock"
                       Foreground="{Binding TextForeground}"
                       TextWrapping="Wrap"
                       Padding="6,4"
                       IsHitTestVisible="False"
                       FontSize="12"
                       MaxHeight="95"/>

            <!-- Bottom bar: color dots + tags + actions -->
            <Border Grid.Row="2" Background="#18000000"
                    CornerRadius="0,0,10,10" AllowDrop="True">
                <Grid Margin="6,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Color picker -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <Border x:Name="cardCurrentColor" Style="{DynamicResource ColorDot}"
                                Background="{Binding Color}"
                                MouseDown="CardCurrentColor_MouseDown"/>
                        <Popup Placement="Top"
                               PlacementTarget="{Binding ElementName=cardCurrentColor}"
                               StaysOpen="True" AllowsTransparency="True"
                               PopupAnimation="Fade">
                            <Border Background="{Binding Color}" CornerRadius="6" Padding="5"
                                    BorderBrush="#40000000" BorderThickness="1">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <Border Style="{DynamicResource ColorDot}" Background="#F8F9FA"
                                                Tag="#F8F9FA" MouseDown="ColorDot_MouseDown"/>
                                        <Border Style="{DynamicResource ColorDot}" Background="#FDDED7"
                                                Tag="#FDDED7" MouseDown="ColorDot_MouseDown"/>
                                        <Border Style="{DynamicResource ColorDot}" Background="#FDE8C8"
                                                Tag="#FDE8C8" MouseDown="ColorDot_MouseDown"/>
                                        <Border Style="{DynamicResource ColorDot}" Background="#FEF3C4"
                                                Tag="#FEF3C4" MouseDown="ColorDot_MouseDown"/>
                                        <Border Style="{DynamicResource ColorDot}" Background="#D4EDDA"
                                                Tag="#D4EDDA" MouseDown="ColorDot_MouseDown"/>
                                        <Border Style="{DynamicResource ColorDot}" Background="#C8F0EA"
                                                Tag="#C8F0EA" MouseDown="ColorDot_MouseDown"/>
                                        <Border Style="{DynamicResource ColorDot}" Background="#D0E4F5"
                                                Tag="#D0E4F5" MouseDown="ColorDot_MouseDown"/>
                                        <Border Style="{DynamicResource ColorDot}" Background="#E2D5F6"
                                                Tag="#E2D5F6" MouseDown="ColorDot_MouseDown"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                        <Border Style="{DynamicResource ColorDot}" Background="#3A3A3A"
                                                Tag="#3A3A3A" MouseDown="ColorDot_MouseDown"/>
                                        <Border Style="{DynamicResource ColorDot}" Background="#4A3030"
                                                Tag="#4A3030" MouseDown="ColorDot_MouseDown"/>
                                        <Border Style="{DynamicResource ColorDot}" Background="#304A30"
                                                Tag="#304A30" MouseDown="ColorDot_MouseDown"/>
                                        <Border Style="{DynamicResource ColorDot}" Background="#4A4A30"
                                                Tag="#4A4A30" MouseDown="ColorDot_MouseDown"/>
                                        <Border Style="{DynamicResource ColorDot}" Background="#304A4A"
                                                Tag="#304A4A" MouseDown="ColorDot_MouseDown"/>
                                        <Border Style="{DynamicResource ColorDot}" Background="#4A304A"
                                                Tag="#4A304A" MouseDown="ColorDot_MouseDown"/>
                                        <Border Style="{DynamicResource ColorDot}" Background="#30304A"
                                                Tag="#30304A" MouseDown="ColorDot_MouseDown"/>
                                        <Border Style="{DynamicResource ColorDot}" Background="#4A3A30"
                                                Tag="#4A3A30" MouseDown="ColorDot_MouseDown"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </Popup>
                    </StackPanel>

                    <!-- Tags -->
                    <WrapPanel Grid.Column="1" x:Name="tagsPanel" Margin="4,0,0,0"
                               Orientation="Horizontal" VerticalAlignment="Center"
                               Visibility="Collapsed">
                        <WrapPanel.Style>
                            <Style TargetType="WrapPanel">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding TagIds.Count}" Value="0">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </WrapPanel.Style>
                    </WrapPanel>

                    <!-- Attachment indicator -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal">
                        <TextBlock Text="📎" FontSize="10"
                                   VerticalAlignment="Center"
                                   Margin="0,0,4,0"
                                   ToolTip="Tiene adjuntos">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasAttachments}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <Button Content="↗" Style="{DynamicResource CardBtn}"
                                FontSize="13" Foreground="{Binding TextForeground}"
                                Tag="PopOut"/>
                        <Button Content="⧉" Style="{DynamicResource CardBtn}"
                                FontSize="11" Foreground="{Binding TextForeground}"
                                Tag="Copy"/>
                        <Button Content="✕" Style="{DynamicResource CardBtn}"
                                FontSize="11" Foreground="{Binding TextForeground}"
                                Tag="Delete"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</UserControl>
