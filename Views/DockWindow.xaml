<Window x:Class="QuickNotes.Views.DockWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Dock" Height="300" Width="60"
        Topmost="True"
        ResizeMode="NoResize"
        WindowStyle="None"
        WindowStartupLocation="Manual"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False">

    <Window.Resources>
        <!-- Note icon hover style (subtle brightness overlay) -->
        <Style x:Key="NoteIconBorder" TargetType="Border">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="0.85"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Border CornerRadius="10" Background="#1A1A1A" BorderBrush="#3A3A3A" BorderThickness="1"
            Padding="2,8,2,8">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Note icons list -->
            <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Hidden"
                          HorizontalScrollBarVisibility="Disabled">
                <ItemsControl x:Name="notesList">
                    <ItemsControl.ItemTemplate>
                                                                                                                        <DataTemplate>
                            <Grid>
                                <Border Width="{Binding IconSize}" Height="{Binding IconSize}"
                                        HorizontalAlignment="Center"
                                        Margin="0,3,0,3"
                                        Background="{Binding BgColor}"
                                        CornerRadius="8"
                                        Opacity="{Binding IconOpacity}"
                                        Tag="{Binding NoteId}"
                                        MouseDown="NoteIcon_MouseDown"
                                        Style="{StaticResource NoteIconBorder}">
                                    <TextBlock Text="{Binding Label}" FontSize="18"
                                               FontWeight="Normal"
                                               Foreground="{Binding FgColor}"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>

                                <!-- Open indicator: vertical bar -->
                                <Rectangle Width="2" Height="12" RadiusX="1" RadiusY="1"
                                           HorizontalAlignment="Right"
                                           VerticalAlignment="Center"
                                           Margin="0,0,2,0"
                                           Visibility="{Binding OpenIndicatorVisibility}"
                                           Fill="LimeGreen"/>

                                <!-- Minimized indicator: dot -->
                                <Ellipse Width="4" Height="4"
                                         HorizontalAlignment="Right"
                                         VerticalAlignment="Center"
                                         Margin="0,0,2,0"
                                         Visibility="{Binding MinIndicatorVisibility}"
                                         Fill="Orange"/>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- QN exit button -->
            <Button x:Name="exitDockBtn" Grid.Row="1"
                    Content="QN" FontSize="9"
                    Width="36" Height="22"
                    Background="Transparent" BorderThickness="0"
                    Foreground="#555555"
                    Cursor="Hand"
                    ToolTip="Volver al modo normal"
                    Margin="0,6,0,0"
                    Click="ExitDock_Click">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="bg"
                                            Background="Transparent"
                                            CornerRadius="4"
                                            Padding="6,2">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="bg" Property="Background" Value="#2A2A2A"/>
                                            <Setter TargetName="bg" Property="BorderBrush" Value="#555555"/>
                                            <Setter TargetName="bg" Property="BorderThickness" Value="1"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Button.Style>
            </Button>
        </Grid>
    </Border>
</Window>





