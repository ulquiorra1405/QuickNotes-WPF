<Window x:Class="QuickNotes.NoteWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:QuickNotes.Helpers"
        xmlns:wpf="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Note" Height="260" Width="340"
        Topmost="True"
        ResizeMode="CanResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="Manual"
        UseLayoutRounding="True"
        FontFamily="Segoe UI">

    <Window.Resources>
        <Style x:Key="MenuItemStyle" TargetType="Border">
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#55FFFFFF"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ReminderCalendarDayButtonStyle"
               TargetType="CalendarDayButton"
               BasedOn="{StaticResource MaterialDesignCalendarDayButton}">
            <Setter Property="wpf:CalendarAssist.SelectionColor" Value="#4A7DB5"/>
            <Setter Property="wpf:CalendarAssist.SelectionForegroundColor" Value="White"/>
        </Style>

        <Style x:Key="ReminderCalendarStyle" TargetType="Calendar"
               BasedOn="{StaticResource MaterialDesignCalendarPortraitForeground}">
            <Setter Property="Background" Value="#1A1A1A"/>
            <Setter Property="Foreground" Value="#DDDDDD"/>
            <Setter Property="BorderBrush" Value="#60FFFFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="wpf:CalendarAssist.HeaderBackground" Value="Transparent"/>
            <Setter Property="wpf:CalendarAssist.HeaderForeground" Value="#DDDDDD"/>
            <Setter Property="CalendarDayButtonStyle" Value="{StaticResource ReminderCalendarDayButtonStyle}"/>
        </Style>
        <Style x:Key="ColorDot" TargetType="Border">
            <Setter Property="Width" Value="16"/>
            <Setter Property="Height" Value="16"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Margin" Value="3,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="BorderBrush" Value="#40000000"/>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="#80000000"/>
                    <Setter Property="RenderTransform">
                        <Setter.Value>
                            <ScaleTransform ScaleX="1.22" ScaleY="1.22"/>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="CloseBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Width" Value="22"/>
            <Setter Property="Height" Value="22"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg" Background="Transparent"
                                CornerRadius="4" Padding="0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#3FFFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TitleBtn" TargetType="ButtonBase">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Width" Value="24"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ButtonBase">
                        <Border x:Name="bg" Background="Transparent"
                                CornerRadius="4" Padding="0"
                                RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <ScaleTransform x:Name="scaleTf" ScaleX="1" ScaleY="1"/>
                            </Border.RenderTransform>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#3FFFFFFF"/>
                            </Trigger>
                            <EventTrigger RoutedEvent="ButtonBase.Click">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="scaleTf" Storyboard.TargetProperty="ScaleX"
                                                        From="0.7" To="1" Duration="0:0:0.15">
                                            <DoubleAnimation.EasingFunction>
                                                <QuadraticEase/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="scaleTf" Storyboard.TargetProperty="ScaleY"
                                                        From="0.7" To="1" Duration="0:0:0.15">
                                            <DoubleAnimation.EasingFunction>
                                                <QuadraticEase/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Border x:Name="windowRoot" CornerRadius="12">
        <Border.Effect>
            <DropShadowEffect ShadowDepth="2" Color="#000000" Opacity="0.4" BlurRadius="12" Direction="270"/>
        </Border.Effect>
        <Grid>
        <!-- Zen backdrop layer (captured desktop + blur + tint) -->
        <Grid x:Name="zenBackdropLayer" Visibility="Collapsed">
            <Image x:Name="zenDesktopImage" Stretch="Fill"
                   RenderOptions.BitmapScalingMode="HighQuality"
                   HorizontalAlignment="Stretch"
                   VerticalAlignment="Stretch">
                <Image.Effect>
                    <BlurEffect Radius="24" KernelType="Gaussian"/>
                </Image.Effect>
            </Image>
            <Rectangle Fill="#70000000"/>
        </Grid>
        <Border x:Name="micaBackdrop" CornerRadius="12" ClipToBounds="True">
        <Grid x:Name="rootContentGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Border x:Name="zenCard" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
        <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title bar with editable title -->
        <Border x:Name="titleBar" Grid.Row="0" Background="#18000000" Padding="0" Height="30"
                PreviewMouseDown="TitleBar_PreviewMouseDown">
            <Grid>
                <TextBlock x:Name="titleDisplay"
                           Text="{Binding Title}"
                           Foreground="{Binding TextForeground}" Opacity="0.67"
                           FontSize="12" FontWeight="SemiBold"
                           VerticalAlignment="Center" Padding="8,0,0,0"/>

                <TextBox x:Name="titleInput"
                         Visibility="Collapsed"
                         Background="Transparent" BorderThickness="0"
                         Foreground="{Binding TextForeground}" Opacity="0.67"
                         FontSize="12" FontWeight="SemiBold"
                         VerticalAlignment="Center" Padding="8,0,0,0"
                         WindowChrome.IsHitTestVisibleInChrome="True"
                         Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}"
                         LostFocus="TitleInput_LostFocus"
                         KeyDown="TitleInput_KeyDown"
                         TextChanged="Title_TextChanged"/>

                <StackPanel x:Name="titleRightPanel" HorizontalAlignment="Right" Orientation="Horizontal">
                    <Button x:Name="pinNoteBtn"
                            WindowChrome.IsHitTestVisibleInChrome="True"
                            Style="{StaticResource TitleBtn}"
                            Click="PinNote_Click">
                        <Path x:Name="pinIcon" Data="{StaticResource IconPin}"
                              Stretch="Uniform" Width="14" Height="14"/>
                    </Button>
                    <Path x:Name="reminderIndicator" Data="{StaticResource IconBell}"
                          Stretch="Uniform" Width="12" Height="12"
                          Visibility="Collapsed"
                          WindowChrome.IsHitTestVisibleInChrome="False"
                          VerticalAlignment="Center" Margin="2,0"/>
                    <Button x:Name="exportMenuBtn" Style="{StaticResource TitleBtn}"
                            WindowChrome.IsHitTestVisibleInChrome="True"
                            ToolTip="Exportar / Importar"
                            Click="ExportMenu_Click">
                        <Path x:Name="exportMenuBtnPath" Data="{StaticResource IconOptions}"
                              Stretch="Uniform" Width="14" Height="14"
                              StrokeThickness="1.0"/>
                    </Button>
                    <Popup x:Name="exportPopup" Placement="Bottom"
                           PlacementTarget="{Binding ElementName=exportMenuBtn}"
                           StaysOpen="False" AllowsTransparency="True"
                           PopupAnimation="Fade">
                        <Border Background="#2A2A2A" CornerRadius="8" Padding="4"
                                BorderBrush="#40FFFFFF" BorderThickness="0.5"
                                MinWidth="140">
                            <StackPanel>
                                <TextBlock Text="Opciones" FontSize="11"
                                           Foreground="#80FFFFFF" Padding="6,2,6,4"
                                           FontWeight="SemiBold"/>
                                <Separator Background="#30FFFFFF" Margin="4,0"/>
                                <Border x:Name="reminderMenuBtn" Style="{StaticResource MenuItemStyle}"
                                        MouseDown="ReminderMenu_Click">
                                    <StackPanel Orientation="Horizontal">
                                        <Path Data="{StaticResource IconBell}"
                                              Stretch="Uniform" Width="12" Height="12"
                                              Stroke="{DynamicResource SidebarIconBrush}"
                                              StrokeThickness="1.5"
                                              VerticalAlignment="Center" Margin="0,0,4,0"/>
                                        <TextBlock Text="Recordatorio..." FontSize="12" Foreground="#EEFFFFFF"/>
                                    </StackPanel>
                                </Border>
                                <Separator Background="#30FFFFFF" Margin="4,0"/>
                                <TextBlock Text="Exportar como..." FontSize="11"
                                           Foreground="#80FFFFFF" Padding="6,2,6,4"
                                           FontWeight="SemiBold"/>
                                <Border Style="{StaticResource MenuItemStyle}" MouseDown="ExportMarkdown_Click">
                                    <TextBlock Text="📄  Markdown (.md)" FontSize="12" Foreground="#EEFFFFFF"/>
                                </Border>
                                <Border Style="{StaticResource MenuItemStyle}" MouseDown="ExportText_Click">
                                    <TextBlock Text="📄  Texto plano (.txt)" FontSize="12" Foreground="#EEFFFFFF"/>
                                </Border>
                                <Border Style="{StaticResource MenuItemStyle}" MouseDown="ExportHtml_Click">
                                    <TextBlock Text="🌐  HTML (.html)" FontSize="12" Foreground="#EEFFFFFF"/>
                                </Border>
                                <Separator Background="#30FFFFFF" Margin="4,0"/>
                                <Border Style="{StaticResource MenuItemStyle}" MouseDown="ImportFile_Click">
                                    <TextBlock Text="📥  Importar archivo..." FontSize="12" Foreground="#EEFFFFFF"/>
                                </Border>
                                <Separator Background="#30FFFFFF" Margin="4,0"/>
                                <Border Style="{StaticResource MenuItemStyle}" MouseDown="ToggleZenFromMenu_Click">
                                    <TextBlock Text="🧘  Modo Zen" FontSize="12" Foreground="#EEFFFFFF"/>
                                </Border>
                            </StackPanel>
                        </Border>
                    </Popup>
                    <Popup x:Name="reminderPopup" Placement="Bottom"
                           PlacementTarget="{Binding ElementName=exportMenuBtn}"
                           StaysOpen="False"
                           AllowsTransparency="True">
                        <Grid Width="300">
                            <Border CornerRadius="10" BorderBrush="#40FFFFFF" BorderThickness="1"
                                    Background="Transparent"/>
                            <Border CornerRadius="10" Background="#262626" Padding="14" ClipToBounds="True">
                                <StackPanel>
                                    <TextBlock Text="🔔  Recordatorio" FontSize="13"
                                               FontWeight="SemiBold" Foreground="#D0D0D0"
                                               Margin="0,0,0,8" Background="Transparent"/>
                                    <Separator Background="#30FFFFFF" Margin="0,0,0,10"/>

                                    <TextBlock Text="Fecha" FontSize="11"
                                               Foreground="#80FFFFFF" Margin="0,0,0,4" Background="Transparent"/>
                                    <Border Background="#1E1E1E" CornerRadius="6" Padding="6,0,6,0"
                                            BorderBrush="#40FFFFFF" BorderThickness="1" Margin="0,0,0,10"
                                            Height="34">
                                        <DatePicker x:Name="reminderDatePicker"
                                                    FirstDayOfWeek="Monday"
                                                    Foreground="#DDDDDD"
                                                    Background="#1E1E1E"
                                                    BorderThickness="0"
                                                    Height="32"
                                                    VerticalAlignment="Center"
                                                    VerticalContentAlignment="Center"
                                                    CalendarStyle="{StaticResource ReminderCalendarStyle}">
                                            <DatePicker.Resources>
                                                <Style TargetType="DatePickerTextBox">
                                                    <Setter Property="Background" Value="Transparent"/>
                                                    <Setter Property="Foreground" Value="#DDDDDD"/>
                                                    <Setter Property="BorderThickness" Value="0"/>
                                                    <Setter Property="CaretBrush" Value="#DDDDDD"/>
                                                    <Setter Property="FontSize" Value="12"/>
                                                    <Setter Property="VerticalContentAlignment" Value="Center"/>
                                                    <Setter Property="Padding" Value="8,0,0,0"/>
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate TargetType="DatePickerTextBox">
                                                                <Border Background="Transparent"
                                                                        BorderThickness="0" CornerRadius="0"
                                                                        Padding="0,0,4,0">
                                                                    <ScrollViewer x:Name="PART_ContentHost"
                                                                                  VerticalAlignment="Center"/>
                                                                </Border>
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                </Style>
                                            </DatePicker.Resources>
                                        </DatePicker>
                                    </Border>

                                    <TextBlock Text="Hora" FontSize="11"
                                               Foreground="#80FFFFFF" Margin="0,0,0,4" Background="Transparent"/>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,10">
                                        <StackPanel Orientation="Horizontal">
                                            <Border Background="#1E1E1E" CornerRadius="6" Padding="6,0"
                                                    BorderBrush="#30FFFFFF" BorderThickness="1"
                                                    Width="46" Height="32" VerticalAlignment="Center">
                                                <TextBox x:Name="reminderHourBox"
                                                         Text="12"
                                                         Foreground="#D0D0D0"
                                                         Background="Transparent"
                                                         BorderThickness="0"
                                                         CaretBrush="#D0D0D0"
                                                         MaxLength="2"
                                                         VerticalAlignment="Center"
                                                         TextAlignment="Center"
                                                         FontSize="14"
                                                         wpf:TextFieldAssist.CharacterCounterVisibility="Collapsed"
                                                         PreviewTextInput="NumericOnly_PreviewTextInput">
                                                    <TextBox.Resources>
                                                        <Style TargetType="TextBox">
                                                            <Setter Property="Template">
                                                                <Setter.Value>
                                                                    <ControlTemplate TargetType="TextBox">
                                                                        <Border Background="Transparent"
                                                                                BorderThickness="0" CornerRadius="0">
                                                                            <ScrollViewer x:Name="PART_ContentHost"
                                                                                          VerticalAlignment="Center"/>
                                                                        </Border>
                                                                    </ControlTemplate>
                                                                </Setter.Value>
                                                            </Setter>
                                                        </Style>
                                                    </TextBox.Resources>
                                                </TextBox>
                                            </Border>
                                            <StackPanel VerticalAlignment="Center" Margin="2,0,6,0">
                                                <Button Width="14" Height="12" FontSize="6" Padding="0"
                                                        Background="Transparent" Foreground="#80FFFFFF"
                                                        BorderThickness="0" Cursor="Hand"
                                                        Click="HourUp_Click">
                                                    <Button.Template>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border x:Name="bg" Background="{TemplateBinding Background}"
                                                                    CornerRadius="2" BorderThickness="0">
                                                                <TextBlock Text="▲" FontSize="7" HorizontalAlignment="Center"
                                                                           VerticalAlignment="Center" Foreground="{TemplateBinding Foreground}"/>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="bg" Property="Background" Value="#3A3A3A"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Button.Template>
                                                </Button>
                                                <Button Width="14" Height="12" FontSize="6" Padding="0" Margin="0,1,0,0"
                                                        Background="Transparent" Foreground="#80FFFFFF"
                                                        BorderThickness="0" Cursor="Hand"
                                                        Click="HourDown_Click">
                                                    <Button.Template>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border x:Name="bg" Background="{TemplateBinding Background}"
                                                                    CornerRadius="2" BorderThickness="0">
                                                                <TextBlock Text="▼" FontSize="7" HorizontalAlignment="Center"
                                                                           VerticalAlignment="Center" Foreground="{TemplateBinding Foreground}"/>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="bg" Property="Background" Value="#3A3A3A"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Button.Template>
                                                </Button>
                                            </StackPanel>
                                        </StackPanel>

                                        <TextBlock Text=":" Foreground="#80FFFFFF" FontSize="18"
                                                   VerticalAlignment="Center" Margin="0,0,6,3" Background="Transparent"/>

                                        <StackPanel Orientation="Horizontal" Margin="0,0,8,0">
                                            <Border Background="#1E1E1E" CornerRadius="6" Padding="6,0"
                                                    BorderBrush="#30FFFFFF" BorderThickness="1"
                                                    Width="46" Height="32" VerticalAlignment="Center">
                                                <TextBox x:Name="reminderMinuteBox"
                                                         Text="00"
                                                         Foreground="#D0D0D0"
                                                         Background="Transparent"
                                                         BorderThickness="0"
                                                         CaretBrush="#D0D0D0"
                                                         MaxLength="2"
                                                         VerticalAlignment="Center"
                                                         TextAlignment="Center"
                                                         FontSize="14"
                                                         wpf:TextFieldAssist.CharacterCounterVisibility="Collapsed"
                                                         PreviewTextInput="NumericOnly_PreviewTextInput">
                                                    <TextBox.Resources>
                                                        <Style TargetType="TextBox">
                                                            <Setter Property="Template">
                                                                <Setter.Value>
                                                                    <ControlTemplate TargetType="TextBox">
                                                                        <Border Background="Transparent"
                                                                                BorderThickness="0" CornerRadius="0">
                                                                            <ScrollViewer x:Name="PART_ContentHost"
                                                                                          VerticalAlignment="Center"/>
                                                                        </Border>
                                                                    </ControlTemplate>
                                                                </Setter.Value>
                                                            </Setter>
                                                        </Style>
                                                    </TextBox.Resources>
                                                </TextBox>
                                            </Border>
                                            <StackPanel VerticalAlignment="Center" Margin="2,0,0,0">
                                                <Button Width="14" Height="12" FontSize="6" Padding="0"
                                                        Background="Transparent" Foreground="#80FFFFFF"
                                                        BorderThickness="0" Cursor="Hand"
                                                        Click="MinuteUp_Click">
                                                    <Button.Template>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border x:Name="bg" Background="{TemplateBinding Background}"
                                                                    CornerRadius="2" BorderThickness="0">
                                                                <TextBlock Text="▲" FontSize="7" HorizontalAlignment="Center"
                                                                           VerticalAlignment="Center" Foreground="{TemplateBinding Foreground}"/>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="bg" Property="Background" Value="#3A3A3A"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Button.Template>
                                                </Button>
                                                <Button Width="14" Height="12" FontSize="6" Padding="0" Margin="0,1,0,0"
                                                        Background="Transparent" Foreground="#80FFFFFF"
                                                        BorderThickness="0" Cursor="Hand"
                                                        Click="MinuteDown_Click">
                                                    <Button.Template>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border x:Name="bg" Background="{TemplateBinding Background}"
                                                                    CornerRadius="2" BorderThickness="0">
                                                                <TextBlock Text="▼" FontSize="7" HorizontalAlignment="Center"
                                                                           VerticalAlignment="Center" Foreground="{TemplateBinding Foreground}"/>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="bg" Property="Background" Value="#3A3A3A"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Button.Template>
                                                </Button>
                                            </StackPanel>
                                        </StackPanel>

                                        <StackPanel Orientation="Horizontal">
                                            <Border Background="#1E1E1E" CornerRadius="6" Padding="6,0"
                                                    BorderBrush="#30FFFFFF" BorderThickness="1"
                                                    Width="46" Height="32" VerticalAlignment="Center">
                                                <TextBlock x:Name="reminderAmPmText"
                                                           Text="AM"
                                                           Foreground="#D0D0D0"
                                                           VerticalAlignment="Center"
                                                           TextAlignment="Center"
                                                           FontSize="14"
                                                           Background="Transparent"/>
                                            </Border>
                                            <StackPanel VerticalAlignment="Center" Margin="2,0,0,0">
                                                <Button Width="14" Height="12" FontSize="6" Padding="0"
                                                        Background="Transparent" Foreground="#80FFFFFF"
                                                        BorderThickness="0" Cursor="Hand"
                                                        Click="AmPmToggle_Click">
                                                    <Button.Template>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border x:Name="bg" Background="{TemplateBinding Background}"
                                                                    CornerRadius="2" BorderThickness="0">
                                                                <TextBlock Text="▲" FontSize="7" HorizontalAlignment="Center"
                                                                           VerticalAlignment="Center" Foreground="{TemplateBinding Foreground}"/>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="bg" Property="Background" Value="#3A3A3A"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Button.Template>
                                                </Button>
                                                <Button Width="14" Height="12" FontSize="6" Padding="0" Margin="0,1,0,0"
                                                        Background="Transparent" Foreground="#80FFFFFF"
                                                        BorderThickness="0" Cursor="Hand"
                                                        Click="AmPmToggle_Click">
                                                    <Button.Template>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border x:Name="bg" Background="{TemplateBinding Background}"
                                                                    CornerRadius="2" BorderThickness="0">
                                                                <TextBlock Text="▼" FontSize="7" HorizontalAlignment="Center"
                                                                           VerticalAlignment="Center" Foreground="{TemplateBinding Foreground}"/>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="bg" Property="Background" Value="#3A3A3A"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Button.Template>
                                                </Button>
                                            </StackPanel>
                                        </StackPanel>
                                    </StackPanel>

                                    <TextBlock Text="Título (opcional)" FontSize="11"
                                               Foreground="#80FFFFFF" Margin="0,0,0,4" Background="Transparent"/>
                                    <Border Background="#1E1E1E" CornerRadius="6" Padding="8,0"
                                            BorderBrush="#30FFFFFF" BorderThickness="1" Margin="0,0,0,6">
                                        <TextBox x:Name="reminderTitleBox"
                                                 Text="" Height="30"
                                                 Foreground="#D0D0D0"
                                                 Background="#1E1E1E"
                                                 BorderThickness="0"
                                                 CaretBrush="#D0D0D0"
                                                 VerticalAlignment="Center"
                                                 FontSize="12"/>
                                    </Border>

                                    <TextBlock Text="Descripción" FontSize="11"
                                               Foreground="#60FFFFFF" Margin="0,0,0,4" Background="Transparent"/>
                                    <Border Background="#1A1A1A" CornerRadius="6" Padding="8,6"
                                            BorderBrush="#20FFFFFF" BorderThickness="1" Margin="0,0,0,12"
                                            MaxHeight="80">
                                        <TextBox x:Name="reminderDescBox"
                                                 Text=""
                                                 Foreground="#909090"
                                                 Background="Transparent"
                                                 BorderThickness="0"
                                                 TextWrapping="Wrap"
                                                 FontSize="11"
                                                 VerticalAlignment="Top"
                                                 VerticalScrollBarVisibility="Auto"
                                                 GotFocus="ReminderDescBox_GotFocus"
                                                 LostFocus="ReminderDescBox_LostFocus"/>
                                    </Border>

                                    <Separator Background="#30FFFFFF" Margin="0,0,0,10"/>

                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                        <Button x:Name="reminderDeleteBtn"
                                                Content="✕ Quitar"
                                                Visibility="Collapsed"
                                                Margin="0,0,8,0"
                                                FontSize="12" Cursor="Hand"
                                                Background="#3A3A3A" Foreground="#CC6666"
                                                BorderThickness="0" Padding="10,6"
                                                Click="DeleteReminder_Click">
                                            <Button.Style>
                                                <Style TargetType="Button">
                                                    <Setter Property="Background" Value="#3A3A3A"/>
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate TargetType="Button">
                                                                <Border x:Name="bg" Background="{TemplateBinding Background}"
                                                                        CornerRadius="5" Padding="{TemplateBinding Padding}"
                                                                        BorderThickness="0">
                                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                </Border>
                                                                <ControlTemplate.Triggers>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter TargetName="bg" Property="Background" Value="#5A3A3A"/>
                                                                    </Trigger>
                                                                </ControlTemplate.Triggers>
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                        <Button x:Name="reminderSaveBtn"
                                                Content="Guardar"
                                                FontSize="12" Cursor="Hand" Padding="14,6"
                                                Background="#3A3A3A" Foreground="#D0D0D0"
                                                BorderThickness="0"
                                                Click="ScheduleReminder_Click">
                                            <Button.Style>
                                                <Style TargetType="Button">
                                                    <Setter Property="Background" Value="#3A3A3A"/>
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate TargetType="Button">
                                                                <Border x:Name="bg" Background="{TemplateBinding Background}"
                                                                        CornerRadius="5" Padding="{TemplateBinding Padding}"
                                                                        BorderThickness="0">
                                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                </Border>
                                                                <ControlTemplate.Triggers>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter TargetName="bg" Property="Background" Value="#555555"/>
                                                                    </Trigger>
                                                                </ControlTemplate.Triggers>
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Popup>
                    <Button Style="{StaticResource TitleBtn}"
                            WindowChrome.IsHitTestVisibleInChrome="True"
                            ToolTip="Minimizar al dock"
                            Click="MinimizeNote_Click">
                        <Path x:Name="minBtnPath" Data="{StaticResource IconMin}"
                              Stretch="Uniform" Width="12" Height="12"
                              StrokeThickness="1.5"/>
                    </Button>
                    <Button Style="{StaticResource CloseBtn}" Margin="0,0,6,0"
                            WindowChrome.IsHitTestVisibleInChrome="True"
                            Click="Close_Click">
                        <Path x:Name="closeBtnPath" Data="{StaticResource IconExit}"
                              Stretch="Uniform" Width="12" Height="12"
                              StrokeThickness="1.5"/>
                    </Button>
                </StackPanel>

                <Border x:Name="noteSearchBorder" Visibility="Collapsed"
                        WindowChrome.IsHitTestVisibleInChrome="True"
                        Background="#1E1E1E" BorderBrush="#3A3A3A"
                        BorderThickness="0" CornerRadius="0"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch" Margin="0" Padding="8,0,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="searchIcon" Grid.Column="0" Text="🔍" FontSize="11"
                                   VerticalAlignment="Center" Margin="0,0,4,0"
                                   Foreground="#88DDDDDD"/>
                        <TextBox x:Name="noteSearchBox" Grid.Column="1"
                                 WindowChrome.IsHitTestVisibleInChrome="True"
                                 Background="Transparent" BorderThickness="0"
                                 Foreground="#DDDDDD" FontSize="12"
                                 VerticalAlignment="Center"
                                 Padding="2,0,4,0"
                                 TextChanged="NoteSearch_TextChanged"
                                 LostFocus="NoteSearch_LostFocus"
                                 PreviewKeyDown="NoteSearch_PreviewKeyDown"/>
                        <TextBlock x:Name="noteSearchHint" Grid.Column="1"
                                   Text="Buscar en la nota..."
                                   Foreground="#66DDDDDD" FontSize="12"
                                   IsHitTestVisible="False"
                                   VerticalAlignment="Center"
                                   Padding="2,0,4,0"/>
                        <TextBlock x:Name="searchCounter" Grid.Column="2"
                                   Text="" FontSize="10"
                                   VerticalAlignment="Center"
                                   Foreground="#66DDDDDD"
                                   Margin="4,0,4,0"
                                   IsHitTestVisible="False"/>
                        <Button x:Name="searchCloseBtn" Grid.Column="3"
                                Content="✕" Width="24" Height="24"
                                Style="{StaticResource TitleBtn}"
                                Foreground="#88DDDDDD" FontSize="10"
                                WindowChrome.IsHitTestVisibleInChrome="True"
                                ToolTip="Cerrar (Escape)"
                                Click="SearchClose_Click"/>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <!-- Note text -->
        <Grid Grid.Row="1">
            <Border x:Name="zenWrapper" HorizontalAlignment="Stretch">
                <Grid>
                    <Grid>
                        <local:NoteRichTextBox x:Name="noteText"
                                     Background="Transparent" BorderThickness="0"
                                     Foreground="{Binding TextForeground}" FontFamily="Calibri" FontSize="13"
                                     Padding="10,2,15,6"
                                     VerticalScrollBarVisibility="Auto"
                                     ScrollViewer.CanContentScroll="False"
                                     AcceptsTab="True"
                                     Loaded="NoteText_Loaded"
                                     LostFocus="Text_LostFocus"
                                     TextChanged="NoteText_TextChanged"
                                     PreviewMouseLeftButtonDown="NoteText_PreviewMouseDown"
                                     PreviewMouseMove="NoteText_PreviewMouseMove"
                                     SelectionChanged="NoteText_SelectionChanged"
                                     IsDocumentEnabled="True">
                            <local:NoteRichTextBox.Resources>
                                <Style TargetType="Paragraph">
                                    <Setter Property="Margin" Value="0"/>
                                    <Setter Property="LineHeight" Value="18"/>
                                    <Setter Property="LineStackingStrategy" Value="BlockLineHeight"/>
                                </Style>
                            </local:NoteRichTextBox.Resources>
                        </local:NoteRichTextBox>
                        <!-- Search highlight overlay (no document modification) -->
                        <Canvas x:Name="searchCanvas" IsHitTestVisible="False"
                                ClipToBounds="True" Visibility="Collapsed"/>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <!-- Attachment bar -->
        <Border Grid.Row="2" x:Name="attachmentBar"
                Background="#14000000" Padding="6,2"
                Height="28" Visibility="Collapsed">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Path Grid.Column="0"
                      Data="{StaticResource IconPaperclip}"
                      Stretch="Uniform" Width="12" Height="12"
                      VerticalAlignment="Center" Margin="2,0,4,0"
                      Fill="#88DDDDDD"/>
                <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Hidden"
                              HorizontalScrollBarVisibility="Auto"
                              VerticalAlignment="Center">
                    <StackPanel x:Name="attachmentsStack" Orientation="Horizontal"/>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- Bottom bar: color picker (collapsed) + format buttons -->
        <Border x:Name="colorBar" Grid.Row="3" Background="#18000000" Padding="8,0" Height="32">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border x:Name="currentColorDot" Style="{StaticResource ColorDot}"
                            Background="{Binding Color}"
                            MouseDown="CurrentColorDot_MouseDown"/>
                    <Popup x:Name="colorPopup" Placement="Top"
                           PlacementTarget="{Binding ElementName=currentColorDot}"
                           StaysOpen="True" AllowsTransparency="True"
                           PopupAnimation="Fade">
                         <Border Background="{Binding Color}" CornerRadius="6" Padding="5"
                                 BorderBrush="#40000000" BorderThickness="1">
                             <StackPanel>
                                 <StackPanel Orientation="Horizontal">
                                     <Border Style="{StaticResource ColorDot}" Background="#F8F9FA"
                                             Tag="#F8F9FA" MouseDown="ColorDot_MouseDown"/>
                                     <Border Style="{StaticResource ColorDot}" Background="#FDDED7"
                                             Tag="#FDDED7" MouseDown="ColorDot_MouseDown"/>
                                     <Border Style="{StaticResource ColorDot}" Background="#FDE8C8"
                                             Tag="#FDE8C8" MouseDown="ColorDot_MouseDown"/>
                                     <Border Style="{StaticResource ColorDot}" Background="#FEF3C4"
                                             Tag="#FEF3C4" MouseDown="ColorDot_MouseDown"/>
                                     <Border Style="{StaticResource ColorDot}" Background="#D4EDDA"
                                             Tag="#D4EDDA" MouseDown="ColorDot_MouseDown"/>
                                     <Border Style="{StaticResource ColorDot}" Background="#C8F0EA"
                                             Tag="#C8F0EA" MouseDown="ColorDot_MouseDown"/>
                                     <Border Style="{StaticResource ColorDot}" Background="#D0E4F5"
                                             Tag="#D0E4F5" MouseDown="ColorDot_MouseDown"/>
                                     <Border Style="{StaticResource ColorDot}" Background="#E2D5F6"
                                             Tag="#E2D5F6" MouseDown="ColorDot_MouseDown"/>
                                 </StackPanel>
                                 <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                     <Border Style="{StaticResource ColorDot}" Background="#3A3A3A"
                                             Tag="#3A3A3A" MouseDown="ColorDot_MouseDown"/>
                                     <Border Style="{StaticResource ColorDot}" Background="#4A3030"
                                             Tag="#4A3030" MouseDown="ColorDot_MouseDown"/>
                                     <Border Style="{StaticResource ColorDot}" Background="#304A30"
                                             Tag="#304A30" MouseDown="ColorDot_MouseDown"/>
                                     <Border Style="{StaticResource ColorDot}" Background="#4A4A30"
                                             Tag="#4A4A30" MouseDown="ColorDot_MouseDown"/>
                                     <Border Style="{StaticResource ColorDot}" Background="#304A4A"
                                             Tag="#304A4A" MouseDown="ColorDot_MouseDown"/>
                                     <Border Style="{StaticResource ColorDot}" Background="#4A304A"
                                             Tag="#4A304A" MouseDown="ColorDot_MouseDown"/>
                                     <Border Style="{StaticResource ColorDot}" Background="#30304A"
                                             Tag="#30304A" MouseDown="ColorDot_MouseDown"/>
                                     <Border Style="{StaticResource ColorDot}" Background="#4A3A30"
                                             Tag="#4A3A30" MouseDown="ColorDot_MouseDown"/>
                                 </StackPanel>
                             </StackPanel>
                        </Border>
                    </Popup>
                    <Rectangle Width="1" Fill="{Binding TextForeground}" Opacity="0.25" Margin="3,2"/>
                    <Button x:Name="emojiBtn" Width="24" Height="24"
                            Style="{StaticResource TitleBtn}"
                            FontSize="16"
                            Foreground="{Binding TextForeground}"
                            ToolTip="Icono para el dock"
                            Click="EmojiBtn_Click">
                        <Path Data="{StaticResource IconMask}"
                              Stretch="Uniform" Width="18" Height="18"
                              Fill="{Binding TextForeground}"/>
                    </Button>
                    <Popup x:Name="emojiPopup" Placement="Top"
                           PlacementTarget="{Binding ElementName=emojiBtn}"
                           StaysOpen="True" AllowsTransparency="True"
                           PopupAnimation="Fade">
                        <Border Background="{Binding Color}"
                                CornerRadius="6" Padding="5"
                                BorderBrush="#40000000" BorderThickness="1">
                            <Grid TextElement.Foreground="{Binding TextForeground}">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <UniformGrid x:Name="emojiPanel" Grid.Row="0" Columns="6" Rows="4"/>
                                <Grid Grid.Row="1" Margin="0,4,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Button x:Name="emojiIconPrevBtn" Grid.Column="0"
                                            Width="20" Height="20"
                                            Cursor="Hand" ToolTip="Anterior"
                                            Style="{StaticResource TitleBtn}"
                                            Click="EmojiIconPrevPage_Click">
                                        <Path x:Name="emojiIconPrevPath" Data="{StaticResource IconLeft}"
                                              Stretch="Uniform" Width="10" Height="10"
                                              Fill="{Binding TextForeground}"/>
                                    </Button>
                                    <StackPanel x:Name="emojiIconPageDots" Grid.Column="1"
                                                Orientation="Horizontal"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"/>
                                    <Button x:Name="emojiIconNextBtn" Grid.Column="2"
                                            Width="20" Height="20"
                                            Cursor="Hand" ToolTip="Siguiente"
                                            Style="{StaticResource TitleBtn}"
                                            Click="EmojiIconNextPage_Click">
                                        <Path x:Name="emojiIconNextPath" Data="{StaticResource IconRight}"
                                              Stretch="Uniform" Width="10" Height="10"
                                              Fill="{Binding TextForeground}"/>
                                    </Button>
                                </Grid>
                            </Grid>
                        </Border>
                    </Popup>
                    <Button x:Name="hideCompletedBtn"
                            Width="24" Height="22" Cursor="Hand" ToolTip="Ocultar completados"
                            Style="{StaticResource TitleBtn}"
                            Click="HideCompletedBtn_Click">
                        <Path x:Name="hideCompletedIcon" Data="{StaticResource IconEye}"
                              Stretch="Uniform" Width="14" Height="14"
                              StrokeThickness="1.5"/>
                    </Button>
                </StackPanel>

                <StackPanel x:Name="bottomRightPanel" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Rectangle x:Name="sep1" Width="1" Fill="{Binding TextForeground}" Opacity="0.25" Margin="3,2"/>
                    <Button x:Name="checkboxBtn" Width="24" Height="22" Cursor="Hand" ToolTip="Checklist"
                            Style="{StaticResource TitleBtn}"
                            Click="CheckboxBtn_Click">
                        <Path x:Name="checkboxPath" Data="{StaticResource IconCheck}"
                              Stretch="Uniform" Width="14" Height="14"
                              StrokeThickness="1.5"/>
                    </Button>
                    <Button x:Name="emojiInsertBtn" Width="24" Height="22" Cursor="Hand" ToolTip="Insertar emoji"
                            Style="{StaticResource TitleBtn}"
                            Click="EmojiInsertBtn_Click">
                        <Path x:Name="emojiInsertBtnPath" Data="{StaticResource IconEmoji}"
                              Stretch="Uniform" Width="14" Height="14"
                              StrokeThickness="1.5"/>
                    </Button>
                    <Popup x:Name="emojiInsertPopup" Placement="Top"
                           PlacementTarget="{Binding ElementName=emojiInsertBtn}"
                           StaysOpen="True" AllowsTransparency="True"
                           PopupAnimation="Fade">
                        <Border x:Name="emojiInsertBorder"
                                CornerRadius="6" Padding="5"
                                BorderBrush="#40000000" BorderThickness="1"
                                Background="{Binding Color}">
                            <Grid TextElement.Foreground="{Binding TextForeground}">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <UniformGrid x:Name="emojiInsertGrid" Grid.Row="0" Columns="6" Rows="4"/>
                                <Grid Grid.Row="1" Margin="0,4,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Button x:Name="emojiPrevBtn" Grid.Column="0"
                                            Width="20" Height="20"
                                            Cursor="Hand" ToolTip="Anterior"
                                            Style="{StaticResource TitleBtn}"
                                            Click="EmojiPrevPage_Click">
                                        <Path x:Name="emojiPrevPath" Data="{StaticResource IconLeft}"
                                              Stretch="Uniform" Width="10" Height="10"
                                              Fill="{Binding TextForeground}"/>
                                    </Button>
                                    <StackPanel x:Name="emojiPageDots" Grid.Column="1"
                                                Orientation="Horizontal"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"/>
                                    <Button x:Name="emojiNextBtn" Grid.Column="2"
                                            Width="20" Height="20"
                                            Cursor="Hand" ToolTip="Siguiente"
                                            Style="{StaticResource TitleBtn}"
                                            Click="EmojiNextPage_Click">
                                        <Path x:Name="emojiNextPath" Data="{StaticResource IconRight}"
                                              Stretch="Uniform" Width="10" Height="10"
                                              Fill="{Binding TextForeground}"/>
                                    </Button>
                                </Grid>
                            </Grid>
                        </Border>
                    </Popup>
                    <Button x:Name="alignBtn" Width="24" Height="22" Cursor="Hand" ToolTip="Alinear"
                            Style="{StaticResource TitleBtn}"
                            Click="AlignBtn_Click">
                        <Path x:Name="alignBtnPath" Data="{StaticResource IconAlignLeft}"
                              Stretch="Uniform" Width="14" Height="14"/>
                    </Button>
                    <Popup x:Name="alignPopup" Placement="Top"
                           PlacementTarget="{Binding ElementName=alignBtn}"
                           StaysOpen="False" AllowsTransparency="True"
                           PopupAnimation="Fade">
                        <Border Background="{Binding Color}" CornerRadius="6" Padding="4"
                                BorderBrush="#40000000" BorderThickness="1">
                            <StackPanel Orientation="Horizontal" TextElement.Foreground="{Binding TextForeground}">
                                <Button x:Name="alignPopupLeftBtn" Width="28" Height="28"
                                        Style="{StaticResource TitleBtn}"
                                        Click="AlignLeft_Click"
                                        ToolTip="Izquierda">
                                    <Path x:Name="alignPopupLeftPath" Data="{StaticResource IconAlignLeft}"
                                          Stretch="Uniform" Width="16" Height="16"/>
                                </Button>
                                <Button x:Name="alignPopupCenterBtn" Width="28" Height="28"
                                        Style="{StaticResource TitleBtn}"
                                        Click="AlignCenter_Click"
                                        ToolTip="Centrado">
                                    <Path x:Name="alignPopupCenterPath" Data="{StaticResource IconAlignCenter}"
                                          Stretch="Uniform" Width="16" Height="16"/>
                                </Button>
                                <Button x:Name="alignPopupRightBtn" Width="28" Height="28"
                                        Style="{StaticResource TitleBtn}"
                                        Click="AlignRight_Click"
                                        ToolTip="Derecha">
                                    <Path x:Name="alignPopupRightPath" Data="{StaticResource IconAlignRight}"
                                          Stretch="Uniform" Width="16" Height="16"/>
                                </Button>
                                <Button x:Name="alignPopupJustifyBtn" Width="28" Height="28"
                                        Style="{StaticResource TitleBtn}"
                                        Click="AlignJustify_Click"
                                        ToolTip="Justificado">
                                    <Path x:Name="alignPopupJustifyPath" Data="{StaticResource IconAlignJustify}"
                                          Stretch="Uniform" Width="16" Height="16"/>
                                </Button>
                            </StackPanel>
                        </Border>
                    </Popup>
                    <Rectangle x:Name="sep2" Width="1" Fill="#40FFFFFF" Margin="3,2"/>
                    <Button x:Name="undoBtn" Width="24" Height="22" Cursor="Hand" ToolTip="Deshacer (Ctrl+Z)"
                            Style="{StaticResource TitleBtn}"
                            Click="UndoBtn_Click">
                        <Path x:Name="undoBtnPath" Data="{StaticResource IconUndo}"
                              Stretch="Uniform" Width="14" Height="14"
                              StrokeThickness="1.5"/>
                    </Button>
                    <Button x:Name="redoBtn" Width="24" Height="22" Cursor="Hand" ToolTip="Rehacer (Ctrl+Y)"
                            Style="{StaticResource TitleBtn}"
                            Click="RedoBtn_Click">
                        <Path x:Name="redoBtnPath" Data="{StaticResource IconRedo}"
                              Stretch="Uniform" Width="14" Height="14"
                              StrokeThickness="1.5"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Floating format toolbar -->
        <Popup x:Name="formatPopup" StaysOpen="True" Placement="Absolute" Focusable="False">
            <Border BorderBrush="#40000000" BorderThickness="1"
                    CornerRadius="8" Padding="6,3">
                <StackPanel Orientation="Horizontal" x:Name="formatToolbar">
                    <Button x:Name="floatBoldBtn" Content="B" FontWeight="Bold" FontSize="11"
                            Width="26" Height="24" Cursor="Hand" ToolTip="Negrita"
                            Style="{StaticResource TitleBtn}"
                            Click="FloatBold_Click"/>
                    <Button x:Name="floatItalicBtn" Content="I" FontStyle="Italic" FontSize="11"
                            Width="26" Height="24" Cursor="Hand" ToolTip="Cursiva"
                            Style="{StaticResource TitleBtn}"
                            Click="FloatItalic_Click"/>
                    <Button x:Name="floatUnderlineBtn" Content="U" FontSize="11"
                            Width="26" Height="24" Cursor="Hand" ToolTip="Subrayado"
                            Style="{StaticResource TitleBtn}"
                            Click="FloatUnderline_Click">
                        <Button.ContentTemplate>
                            <DataTemplate>
                                <TextBlock Text="U" TextDecorations="Underline"/>
                            </DataTemplate>
                        </Button.ContentTemplate>
                    </Button>
                    <Button x:Name="floatStrikeBtn" Content="S" FontSize="12"
                            Width="26" Height="24" Cursor="Hand" ToolTip="Tachado"
                            Style="{StaticResource TitleBtn}"
                            Click="FloatStrike_Click">
                        <Button.ContentTemplate>
                            <DataTemplate>
                                <TextBlock Text="S" TextDecorations="Strikethrough"/>
                            </DataTemplate>
                        </Button.ContentTemplate>
                    </Button>
                    <Rectangle x:Name="floatSep1" Width="1" Fill="#40FFFFFF" Margin="3,2"/>
                    <Border x:Name="floatHighlightBtn" Width="14" Height="14"
                            CornerRadius="2" Cursor="Hand" Margin="3,0"
                            BorderBrush="#40FFFFFF" BorderThickness="1"
                            ToolTip="Resaltar"
                            MouseDown="FloatHighlight_MouseDown"/>
                    <StackPanel x:Name="floatHighlightPicker" Orientation="Horizontal"
                                Visibility="Collapsed" Opacity="0">
                        <!-- Color dots built in code -->
                    </StackPanel>
                    <Rectangle Width="1" Fill="#40FFFFFF" Margin="3,2"/>
                    <Button x:Name="floatHeadingBtn" Content="H▼" FontSize="10"
                            Width="26" Height="24" Cursor="Hand" ToolTip="Encabezado"
                            Style="{StaticResource TitleBtn}"
                            Click="FloatHeading_Click"/>
                    <StackPanel x:Name="floatHeadingPicker" Orientation="Horizontal"
                                Visibility="Collapsed" Opacity="0">
                        <!-- Heading options built in code -->
                    </StackPanel>

                </StackPanel>
            </Border>
        </Popup>

        </Grid>
    </Border>
    </Grid>
    </Border>
    </Grid>
    </Border>
</Window>

