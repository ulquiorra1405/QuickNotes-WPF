<Window x:Class="QuickNotes.NoteWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:QuickNotes.Helpers"
        Title="Note" Height="260" Width="340"
        Topmost="True"
        ResizeMode="CanResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="Manual"
        UseLayoutRounding="True"
        FontFamily="Segoe UI">

    <Window.Resources>
        <Style x:Key="ColorDot" TargetType="Border">
            <Setter Property="Width" Value="16"/>
            <Setter Property="Height" Value="16"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Margin" Value="3,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="BorderBrush" Value="#40000000"/>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="#80000000"/>
                    <Setter Property="RenderTransform">
                        <Setter.Value>
                            <ScaleTransform ScaleX="1.22" ScaleY="1.22"/>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="CloseBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Width" Value="22"/>
            <Setter Property="Height" Value="22"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg" Background="Transparent"
                                CornerRadius="4" Padding="0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#20000000"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TitleBtn" TargetType="ButtonBase">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Width" Value="24"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ButtonBase">
                        <Border x:Name="bg" Background="Transparent"
                                CornerRadius="4" Padding="0"
                                RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <ScaleTransform x:Name="scaleTf" ScaleX="1" ScaleY="1"/>
                            </Border.RenderTransform>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#20000000"/>
                            </Trigger>
                            <EventTrigger RoutedEvent="ButtonBase.Click">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="scaleTf" Storyboard.TargetProperty="ScaleX"
                                                        From="0.7" To="1" Duration="0:0:0.15">
                                            <DoubleAnimation.EasingFunction>
                                                <QuadraticEase/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="scaleTf" Storyboard.TargetProperty="ScaleY"
                                                        From="0.7" To="1" Duration="0:0:0.15">
                                            <DoubleAnimation.EasingFunction>
                                                <QuadraticEase/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Border x:Name="windowRoot" CornerRadius="12">
        <Border.Effect>
            <DropShadowEffect ShadowDepth="2" Color="#000000" Opacity="0.4" BlurRadius="12" Direction="270"/>
        </Border.Effect>
        <Border x:Name="micaBackdrop" CornerRadius="12" ClipToBounds="True">
        <Grid x:Name="rootContentGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title bar with editable title -->
        <Border x:Name="titleBar" Grid.Row="0" Background="#18000000" Padding="0" Height="30"
                PreviewMouseDown="TitleBar_PreviewMouseDown">
            <Grid>
                <TextBlock x:Name="titleDisplay"
                           Text="{Binding Title}"
                           Foreground="{Binding TextForeground}" Opacity="0.67"
                           FontSize="12" FontWeight="SemiBold"
                           VerticalAlignment="Center" Padding="8,0,0,0"/>

                <TextBox x:Name="titleInput"
                         Visibility="Collapsed"
                         Background="Transparent" BorderThickness="0"
                         Foreground="{Binding TextForeground}" Opacity="0.67"
                         FontSize="12" FontWeight="SemiBold"
                         VerticalAlignment="Center" Padding="8,0,0,0"
                         WindowChrome.IsHitTestVisibleInChrome="True"
                         Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}"
                         LostFocus="TitleInput_LostFocus"
                         KeyDown="TitleInput_KeyDown"
                         TextChanged="Title_TextChanged"/>

                <StackPanel x:Name="titleRightPanel" HorizontalAlignment="Right" Orientation="Horizontal">
                    <Button x:Name="emojiBtn" Width="24" Height="24"
                            Style="{StaticResource TitleBtn}"
                            WindowChrome.IsHitTestVisibleInChrome="True"
                            ToolTip="Icono para el dock"
                            Click="EmojiBtn_Click"
                            Content="📝"/>
                    <Popup x:Name="emojiPopup" Placement="Bottom"
                           PlacementTarget="{Binding ElementName=emojiBtn}"
                           StaysOpen="True" AllowsTransparency="True"
                           PopupAnimation="Fade">
                        <Border Background="{Binding Color}"
                                CornerRadius="6" Padding="5"
                                BorderBrush="#40000000" BorderThickness="1"
                                MaxHeight="200">
                            <ScrollViewer VerticalScrollBarVisibility="Auto" TextElement.Foreground="{Binding TextForeground}">
                                <UniformGrid x:Name="emojiPanel" Columns="6"/>
                            </ScrollViewer>
                        </Border>
                    </Popup>
                    <Button x:Name="pinNoteBtn" FontSize="10" Content="📌"
                            WindowChrome.IsHitTestVisibleInChrome="True"
                            Style="{StaticResource TitleBtn}"
                            Click="PinNote_Click"/>
                    <TextBlock x:Name="reminderIndicator" Text="" FontSize="9"
                               Visibility="Collapsed"
                               WindowChrome.IsHitTestVisibleInChrome="False"
                               VerticalAlignment="Center" Margin="2,0"/>
                    <Button x:Name="exportMenuBtn" Content="⋮" Style="{StaticResource TitleBtn}"
                            WindowChrome.IsHitTestVisibleInChrome="True"
                            ToolTip="Exportar / Importar"
                            Click="ExportMenu_Click" FontSize="14" FontWeight="Bold"/>
                    <Popup x:Name="exportPopup" Placement="Bottom"
                           PlacementTarget="{Binding ElementName=exportMenuBtn}"
                           StaysOpen="False" AllowsTransparency="True"
                           PopupAnimation="Fade">
                        <Border Background="#2A2A2A" CornerRadius="8" Padding="4"
                                BorderBrush="#40FFFFFF" BorderThickness="1"
                                MinWidth="140">
                            <StackPanel>
                                <TextBlock Text="Opciones" FontSize="11"
                                           Foreground="#80FFFFFF" Padding="6,2,6,4"
                                           FontWeight="SemiBold"/>
                                <Separator Background="#30FFFFFF" Margin="4,0"/>
                                <TextBlock x:Name="reminderMenuBtn" Text="🔔  Recordatorio..." FontSize="12"
                                           Foreground="#EEFFFFFF" Padding="6,4" Cursor="Hand"
                                           MouseDown="ReminderMenu_Click">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#3FFFFFFF"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <Separator Background="#30FFFFFF" Margin="4,0"/>
                                <TextBlock Text="Exportar como..." FontSize="11"
                                           Foreground="#80FFFFFF" Padding="6,2,6,4"
                                           FontWeight="SemiBold"/>
                                <TextBlock Text="📄  Markdown (.md)" FontSize="12"
                                           Foreground="#EEFFFFFF" Padding="6,4" Cursor="Hand"
                                           MouseDown="ExportMarkdown_Click">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#3FFFFFFF"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <TextBlock Text="📄  Texto plano (.txt)" FontSize="12"
                                           Foreground="#EEFFFFFF" Padding="6,4" Cursor="Hand"
                                           MouseDown="ExportText_Click">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#3FFFFFFF"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <TextBlock Text="🌐  HTML (.html)" FontSize="12"
                                           Foreground="#EEFFFFFF" Padding="6,4" Cursor="Hand"
                                           MouseDown="ExportHtml_Click">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#3FFFFFFF"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <Separator Background="#30FFFFFF" Margin="4,0"/>
                                <TextBlock Text="📥  Importar archivo..." FontSize="12"
                                           Foreground="#EEFFFFFF" Padding="6,4" Cursor="Hand"
                                           MouseDown="ImportFile_Click">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#3FFFFFFF"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                        </Border>
                    </Popup>
                    <Popup x:Name="reminderPopup" Placement="Bottom"
                           PlacementTarget="{Binding ElementName=exportMenuBtn}"
                           StaysOpen="False" AllowsTransparency="True"
                           PopupAnimation="Fade">
                        <Border Background="#2A2A2A" CornerRadius="8" Padding="10"
                                BorderBrush="#40FFFFFF" BorderThickness="1"
                                MinWidth="220">
                            <StackPanel TextElement.Foreground="#EEFFFFFF" TextElement.FontSize="12">
                                <TextBlock Text="🔔  Recordatorio" FontSize="13"
                                           FontWeight="SemiBold" Margin="0,0,0,8"/>
                                <Separator Background="#30FFFFFF" Margin="0,0,0,8"/>
                                <TextBlock Text="Fecha" Margin="0,0,0,2"/>
                                <DatePicker x:Name="reminderDatePicker"
                                            FirstDayOfWeek="Monday"
                                            Margin="0,0,0,6"
                                            Foreground="Black"/>
                                <TextBlock Text="Hora" Margin="0,0,0,2"/>
                                <TextBox x:Name="reminderTimeBox"
                                         Text="12:00" Width="80"
                                         HorizontalAlignment="Left"
                                         Margin="0,0,0,8"
                                         Foreground="Black"
                                         Background="White"/>
                                <TextBlock Text="Título (opcional)" Margin="0,0,0,2"/>
                                <TextBox x:Name="reminderTitleBox"
                                         Text="" Margin="0,0,0,10"
                                         Foreground="Black" Background="White"/>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <Button x:Name="reminderDeleteBtn"
                                            Content="✕ Quitar"
                                            Visibility="Collapsed"
                                            Margin="0,0,6,0"
                                            Style="{StaticResource TitleBtn}"
                                            Foreground="#FF6666"
                                            Click="DeleteReminder_Click"/>
                                    <Button Content="Programar"
                                            Style="{StaticResource TitleBtn}"
                                            Click="ScheduleReminder_Click"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </Popup>
                    <Button Content="─" Style="{StaticResource TitleBtn}"
                            WindowChrome.IsHitTestVisibleInChrome="True"
                            ToolTip="Minimizar al dock"
                            Click="MinimizeNote_Click"/>
                    <Button Content="✕" Style="{StaticResource CloseBtn}" Margin="0,0,6,0"
                            WindowChrome.IsHitTestVisibleInChrome="True"
                            Click="Close_Click"/>
                </StackPanel>

                <Border x:Name="noteSearchBorder" Visibility="Collapsed"
                        WindowChrome.IsHitTestVisibleInChrome="True"
                        Background="#1E1E1E" BorderBrush="#3A3A3A"
                        BorderThickness="0" CornerRadius="0"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch" Margin="0" Padding="8,0,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="searchIcon" Grid.Column="0" Text="🔍" FontSize="11"
                                   VerticalAlignment="Center" Margin="0,0,4,0"
                                   Foreground="#88DDDDDD"/>
                        <TextBox x:Name="noteSearchBox" Grid.Column="1"
                                 WindowChrome.IsHitTestVisibleInChrome="True"
                                 Background="Transparent" BorderThickness="0"
                                 Foreground="#DDDDDD" FontSize="12"
                                 VerticalAlignment="Center"
                                 Padding="2,0,4,0"
                                 TextChanged="NoteSearch_TextChanged"
                                 LostFocus="NoteSearch_LostFocus"
                                 PreviewKeyDown="NoteSearch_PreviewKeyDown"/>
                        <TextBlock x:Name="noteSearchHint" Grid.Column="1"
                                   Text="Buscar en la nota..."
                                   Foreground="#66DDDDDD" FontSize="12"
                                   IsHitTestVisible="False"
                                   VerticalAlignment="Center"
                                   Padding="2,0,4,0"/>
                        <TextBlock x:Name="searchCounter" Grid.Column="2"
                                   Text="" FontSize="10"
                                   VerticalAlignment="Center"
                                   Foreground="#66DDDDDD"
                                   Margin="4,0,4,0"
                                   IsHitTestVisible="False"/>
                        <Button x:Name="searchCloseBtn" Grid.Column="3"
                                Content="✕" Width="24" Height="24"
                                Style="{StaticResource TitleBtn}"
                                Foreground="#88DDDDDD" FontSize="10"
                                WindowChrome.IsHitTestVisibleInChrome="True"
                                ToolTip="Cerrar (Escape)"
                                Click="SearchClose_Click"/>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <!-- Note text -->
        <Grid Grid.Row="1">
            <local:NoteRichTextBox x:Name="noteText"
                         Background="Transparent" BorderThickness="0"
                         Foreground="{Binding TextForeground}" FontFamily="Calibri" FontSize="13"
                         Padding="10,2,15,6"
                         VerticalScrollBarVisibility="Auto"
                         ScrollViewer.CanContentScroll="False"
                         AcceptsTab="True"
                         Loaded="NoteText_Loaded"
                         LostFocus="Text_LostFocus"
                         TextChanged="NoteText_TextChanged"
                         PreviewMouseLeftButtonDown="NoteText_PreviewMouseDown"
                         PreviewMouseMove="NoteText_PreviewMouseMove"
                         SelectionChanged="NoteText_SelectionChanged"
                         IsDocumentEnabled="True">
                <local:NoteRichTextBox.Resources>
                    <Style TargetType="Paragraph">
                        <Setter Property="Margin" Value="0"/>
                        <Setter Property="LineHeight" Value="18"/>
                        <Setter Property="LineStackingStrategy" Value="BlockLineHeight"/>
                    </Style>
                </local:NoteRichTextBox.Resources>
            </local:NoteRichTextBox>
            <!-- Search highlight overlay (no document modification) -->
            <Canvas x:Name="searchCanvas" IsHitTestVisible="False"
                    ClipToBounds="True" Visibility="Collapsed"/>
        </Grid>

        <!-- Attachment bar -->
        <Border Grid.Row="2" x:Name="attachmentBar"
                Background="#14000000" Padding="6,2"
                Height="28" Visibility="Collapsed">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="📎" FontSize="12"
                           VerticalAlignment="Center" Margin="2,0,4,0"
                           Foreground="#88DDDDDD"/>
                <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Hidden"
                              HorizontalScrollBarVisibility="Auto"
                              VerticalAlignment="Center">
                    <StackPanel x:Name="attachmentsStack" Orientation="Horizontal"/>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- Bottom bar: color picker (collapsed) + format buttons -->
        <Border x:Name="colorBar" Grid.Row="3" Background="#18000000" Padding="8,0" Height="32">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border x:Name="currentColorDot" Style="{StaticResource ColorDot}"
                            Background="{Binding Color}"
                            MouseDown="CurrentColorDot_MouseDown"/>
                    <Popup x:Name="colorPopup" Placement="Top"
                           PlacementTarget="{Binding ElementName=currentColorDot}"
                           StaysOpen="True" AllowsTransparency="True"
                           PopupAnimation="Fade">
                         <Border Background="{Binding Color}" CornerRadius="6" Padding="5"
                                 BorderBrush="#40000000" BorderThickness="1">
                             <StackPanel>
                                 <StackPanel Orientation="Horizontal">
                                     <Border Style="{StaticResource ColorDot}" Background="#F8F9FA"
                                             Tag="#F8F9FA" MouseDown="ColorDot_MouseDown"/>
                                     <Border Style="{StaticResource ColorDot}" Background="#FDDED7"
                                             Tag="#FDDED7" MouseDown="ColorDot_MouseDown"/>
                                     <Border Style="{StaticResource ColorDot}" Background="#FDE8C8"
                                             Tag="#FDE8C8" MouseDown="ColorDot_MouseDown"/>
                                     <Border Style="{StaticResource ColorDot}" Background="#FEF3C4"
                                             Tag="#FEF3C4" MouseDown="ColorDot_MouseDown"/>
                                     <Border Style="{StaticResource ColorDot}" Background="#D4EDDA"
                                             Tag="#D4EDDA" MouseDown="ColorDot_MouseDown"/>
                                     <Border Style="{StaticResource ColorDot}" Background="#C8F0EA"
                                             Tag="#C8F0EA" MouseDown="ColorDot_MouseDown"/>
                                     <Border Style="{StaticResource ColorDot}" Background="#D0E4F5"
                                             Tag="#D0E4F5" MouseDown="ColorDot_MouseDown"/>
                                     <Border Style="{StaticResource ColorDot}" Background="#E2D5F6"
                                             Tag="#E2D5F6" MouseDown="ColorDot_MouseDown"/>
                                 </StackPanel>
                                 <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                     <Border Style="{StaticResource ColorDot}" Background="#3A3A3A"
                                             Tag="#3A3A3A" MouseDown="ColorDot_MouseDown"/>
                                     <Border Style="{StaticResource ColorDot}" Background="#4A3030"
                                             Tag="#4A3030" MouseDown="ColorDot_MouseDown"/>
                                     <Border Style="{StaticResource ColorDot}" Background="#304A30"
                                             Tag="#304A30" MouseDown="ColorDot_MouseDown"/>
                                     <Border Style="{StaticResource ColorDot}" Background="#4A4A30"
                                             Tag="#4A4A30" MouseDown="ColorDot_MouseDown"/>
                                     <Border Style="{StaticResource ColorDot}" Background="#304A4A"
                                             Tag="#304A4A" MouseDown="ColorDot_MouseDown"/>
                                     <Border Style="{StaticResource ColorDot}" Background="#4A304A"
                                             Tag="#4A304A" MouseDown="ColorDot_MouseDown"/>
                                     <Border Style="{StaticResource ColorDot}" Background="#30304A"
                                             Tag="#30304A" MouseDown="ColorDot_MouseDown"/>
                                     <Border Style="{StaticResource ColorDot}" Background="#4A3A30"
                                             Tag="#4A3A30" MouseDown="ColorDot_MouseDown"/>
                                 </StackPanel>
                             </StackPanel>
                        </Border>
                    </Popup>
                </StackPanel>

                <StackPanel x:Name="bottomRightPanel" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Rectangle x:Name="sep1" Width="1" Fill="#40FFFFFF" Margin="3,2"/>
                    <Button x:Name="checkboxBtn" Content="◻" FontSize="14"
                            Width="24" Height="22" Cursor="Hand" ToolTip="Checklist"
                            Style="{StaticResource TitleBtn}"
                            Click="CheckboxBtn_Click"/>
                    <Button x:Name="emojiInsertBtn" Content="😀" FontSize="13"
                            Width="24" Height="22" Cursor="Hand" ToolTip="Insertar emoji"
                            Style="{StaticResource TitleBtn}"
                            Click="EmojiInsertBtn_Click"/>
                    <Popup x:Name="emojiInsertPopup" Placement="Top"
                           PlacementTarget="{Binding ElementName=emojiInsertBtn}"
                           StaysOpen="True" AllowsTransparency="True"
                           PopupAnimation="Fade">
                        <Border x:Name="emojiInsertBorder"
                                CornerRadius="6" Padding="5"
                                BorderBrush="#40000000" BorderThickness="1"
                                Background="{Binding Color}">
                            <Grid TextElement.Foreground="{Binding TextForeground}">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <UniformGrid x:Name="emojiInsertGrid" Grid.Row="0" Columns="6" Rows="4"/>
                                <Grid Grid.Row="1" Margin="0,4,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Button x:Name="emojiPrevBtn" Grid.Column="0" Content="◀"
                                            Width="20" Height="20" FontSize="8"
                                            Cursor="Hand" ToolTip="Anterior"
                                            Style="{StaticResource TitleBtn}"
                                            Click="EmojiPrevPage_Click"/>
                                    <StackPanel x:Name="emojiPageDots" Grid.Column="1"
                                                Orientation="Horizontal"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"/>
                                    <Button x:Name="emojiNextBtn" Grid.Column="2" Content="▶"
                                            Width="20" Height="20" FontSize="8"
                                            Cursor="Hand" ToolTip="Siguiente"
                                            Style="{StaticResource TitleBtn}"
                                            Click="EmojiNextPage_Click"/>
                                </Grid>
                            </Grid>
                        </Border>
                    </Popup>
                    <Button x:Name="alignLeftBtn" Width="24" Height="22" Cursor="Hand" ToolTip="Alinear izquierda"
                            Style="{StaticResource TitleBtn}"
                            Click="AlignLeft_Click">
                        <Grid Width="12" Height="11">
                            <Path x:Name="alignLeftPath" Data="M0,2 L12,2 M0,6 L8,6 M0,10 L5,10"
                                  StrokeThickness="1.2"
                                  StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                  StrokeLineJoin="Round"/>
                        </Grid>
                    </Button>
                    <Button x:Name="alignCenterBtn" Width="24" Height="22" Cursor="Hand" ToolTip="Centrar"
                            Style="{StaticResource TitleBtn}"
                            Click="AlignCenter_Click">
                        <Grid Width="12" Height="11">
                            <Path x:Name="alignCenterPath" Data="M1,2 L11,2 M3,6 L9,6 M5,10 L7,10"
                                  StrokeThickness="1.2"
                                  StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                  StrokeLineJoin="Round"/>
                        </Grid>
                    </Button>
                    <Button x:Name="alignRightBtn" Width="24" Height="22" Cursor="Hand" ToolTip="Alinear derecha"
                            Style="{StaticResource TitleBtn}"
                            Click="AlignRight_Click">
                        <Grid Width="12" Height="11">
                            <Path x:Name="alignRightPath" Data="M0,2 L12,2 M4,6 L12,6 M7,10 L12,10"
                                  StrokeThickness="1.2"
                                  StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                  StrokeLineJoin="Round"/>
                        </Grid>
                    </Button>
                    <Button x:Name="alignJustifyBtn" Width="24" Height="22" Cursor="Hand" ToolTip="Justificar"
                            Style="{StaticResource TitleBtn}"
                            Click="AlignJustify_Click">
                        <Grid Width="12" Height="11">
                            <Path x:Name="alignJustifyPath" Data="M0,2 L12,2 M0,6 L12,6 M0,10 L12,10"
                                  StrokeThickness="1.2"
                                  StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                  StrokeLineJoin="Round"/>
                        </Grid>
                    </Button>
                    <Rectangle x:Name="sep2" Width="1" Fill="#40FFFFFF" Margin="3,2"/>
                    <Button x:Name="undoBtn" Content="↩" FontSize="13"
                            Width="24" Height="22" Cursor="Hand" ToolTip="Deshacer (Ctrl+Z)"
                            Style="{StaticResource TitleBtn}"
                            Click="UndoBtn_Click"/>
                    <Button x:Name="redoBtn" Content="↪" FontSize="13"
                            Width="24" Height="22" Cursor="Hand" ToolTip="Rehacer (Ctrl+Y)"
                            Style="{StaticResource TitleBtn}"
                            Click="RedoBtn_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Floating format toolbar -->
        <Popup x:Name="formatPopup" StaysOpen="True" Placement="Absolute" Focusable="False">
            <Border BorderBrush="#40000000" BorderThickness="1"
                    CornerRadius="8" Padding="6,3">
                <StackPanel Orientation="Horizontal" x:Name="formatToolbar">
                    <Button x:Name="floatBoldBtn" Content="B" FontWeight="Bold" FontSize="11"
                            Width="26" Height="24" Cursor="Hand" ToolTip="Negrita"
                            Style="{StaticResource TitleBtn}"
                            Click="FloatBold_Click"/>
                    <Button x:Name="floatItalicBtn" Content="I" FontStyle="Italic" FontSize="11"
                            Width="26" Height="24" Cursor="Hand" ToolTip="Cursiva"
                            Style="{StaticResource TitleBtn}"
                            Click="FloatItalic_Click"/>
                    <Button x:Name="floatUnderlineBtn" Content="U" FontSize="11"
                            Width="26" Height="24" Cursor="Hand" ToolTip="Subrayado"
                            Style="{StaticResource TitleBtn}"
                            Click="FloatUnderline_Click">
                        <Button.ContentTemplate>
                            <DataTemplate>
                                <TextBlock Text="U" TextDecorations="Underline"/>
                            </DataTemplate>
                        </Button.ContentTemplate>
                    </Button>
                    <Button x:Name="floatStrikeBtn" Content="S" FontSize="12"
                            Width="26" Height="24" Cursor="Hand" ToolTip="Tachado"
                            Style="{StaticResource TitleBtn}"
                            Click="FloatStrike_Click">
                        <Button.ContentTemplate>
                            <DataTemplate>
                                <TextBlock Text="S" TextDecorations="Strikethrough"/>
                            </DataTemplate>
                        </Button.ContentTemplate>
                    </Button>
                    <Rectangle x:Name="floatSep1" Width="1" Fill="#40FFFFFF" Margin="3,2"/>
                    <Border x:Name="floatHighlightBtn" Width="14" Height="14"
                            CornerRadius="2" Cursor="Hand" Margin="3,0"
                            BorderBrush="#40FFFFFF" BorderThickness="1"
                            ToolTip="Resaltar"
                            MouseDown="FloatHighlight_MouseDown"/>
                    <StackPanel x:Name="floatHighlightPicker" Orientation="Horizontal"
                                Visibility="Collapsed" Opacity="0">
                        <!-- Color dots built in code -->
                    </StackPanel>
                    <Rectangle Width="1" Fill="#40FFFFFF" Margin="3,2"/>
                    <Button x:Name="floatHeadingBtn" Content="H▼" FontSize="10"
                            Width="26" Height="24" Cursor="Hand" ToolTip="Encabezado"
                            Style="{StaticResource TitleBtn}"
                            Click="FloatHeading_Click"/>
                    <StackPanel x:Name="floatHeadingPicker" Orientation="Horizontal"
                                Visibility="Collapsed" Opacity="0">
                        <!-- Heading options built in code -->
                    </StackPanel>

                </StackPanel>
            </Border>
        </Popup>

        </Grid>
    </Border>
    </Border>
</Window>

