<Window x:Class="QuickNotes.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:QuickNotes"
        xmlns:views="clr-namespace:QuickNotes.Views"
        mc:Ignorable="d"
        Title="QN" Height="420" Width="380"
        Topmost="True"
        ResizeMode="CanResize"
        WindowStartupLocation="Manual"
        Left="100" Top="100"
        Background="#1E1E1E"
        FontFamily="Segoe UI"
        KeyDown="Window_KeyDown"
        PreviewMouseDown="Window_PreviewMouseDown">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0" ResizeBorderThickness="5"
                      CornerRadius="12"
                      UseAeroCaptionButtons="False" GlassFrameThickness="0"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <local:DateGroupConverter x:Key="DateGroupConverter"/>

        <Style x:Key="ColorDot" TargetType="Border">
            <Setter Property="Width" Value="18"/>
            <Setter Property="Height" Value="18"/>
            <Setter Property="CornerRadius" Value="9"/>
            <Setter Property="Margin" Value="3,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="BorderBrush" Value="#40000000"/>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="#80000000"/>
                    <Setter Property="RenderTransform">
                        <Setter.Value>
                            <ScaleTransform ScaleX="1.22" ScaleY="1.22"/>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="NoteCard" TargetType="Border">
            <Setter Property="Margin" Value="10,5,0,5"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="0"/>
        </Style>

        <Style x:Key="TitleBox" TargetType="TextBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="12,8,12,2"/>
            <Setter Property="MaxLength" Value="60"/>
        </Style>

        <Style x:Key="NoteTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontFamily" Value="Calibri"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="AcceptsReturn" Value="True"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Padding" Value="12,2,3,6"/>
            <Setter Property="MinHeight" Value="40"/>
            <Setter Property="TextBlock.LineHeight" Value="18"/>
            <Setter Property="TextBlock.LineStackingStrategy" Value="BlockLineHeight"/>
        </Style>

        <Style x:Key="HeaderBtn" TargetType="ButtonBase">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="#CCFFFFFF"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Width" Value="30"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ButtonBase">
                        <Border x:Name="bg" Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="0"
                                RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <ScaleTransform x:Name="scaleTf" ScaleX="1" ScaleY="1"/>
                            </Border.RenderTransform>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <EventTrigger RoutedEvent="ButtonBase.Click">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="scaleTf" Storyboard.TargetProperty="ScaleX"
                                                        From="0.7" To="1" Duration="0:0:0.15">
                                            <DoubleAnimation.EasingFunction>
                                                <QuadraticEase/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="scaleTf" Storyboard.TargetProperty="ScaleY"
                                                        From="0.7" To="1" Duration="0:0:0.15">
                                            <DoubleAnimation.EasingFunction>
                                                <QuadraticEase/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CardBtn" TargetType="ButtonBase">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="26"/>
            <Setter Property="Height" Value="26"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ButtonBase">
                        <Border x:Name="bg" Background="{TemplateBinding Background}"
                                CornerRadius="4" Padding="0"
                                RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <ScaleTransform x:Name="scaleTf" ScaleX="1" ScaleY="1"/>
                            </Border.RenderTransform>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#20000000"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#40000000"/>
                            </Trigger>
                            <EventTrigger RoutedEvent="ButtonBase.Click">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="scaleTf" Storyboard.TargetProperty="ScaleX"
                                                        From="0.7" To="1" Duration="0:0:0.15">
                                            <DoubleAnimation.EasingFunction>
                                                <QuadraticEase/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="scaleTf" Storyboard.TargetProperty="ScaleY"
                                                        From="0.7" To="1" Duration="0:0:0.15">
                                            <DoubleAnimation.EasingFunction>
                                                <QuadraticEase/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SidebarItem" TargetType="Border">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="CornerRadius" Value="6"/>
        </Style>

        <Style x:Key="MenuItemBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="#CCFFFFFF"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg" Background="{TemplateBinding Background}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Left"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="26"/>
            </Grid.RowDefinitions>

            <!-- Title Bar -->
            <Border x:Name="titleBar" Grid.Row="0" Background="#262626" Padding="10,0"
                    MouseDown="TitleBar_MouseDown">
                <Grid x:Name="titleBarGrid">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Button x:Name="menuBtn" Grid.Column="0"
                            Style="{StaticResource HeaderBtn}"
                            FontSize="12" FontWeight="SemiBold"
                            Foreground="#BBFFFFFF"
                            Content="QN"
                            Click="MenuBtn_Click"/>
                    <Popup x:Name="menuPopup" Placement="Bottom"
                           PlacementTarget="{Binding ElementName=menuBtn}"
                           StaysOpen="False" AllowsTransparency="True"
                           PopupAnimation="Fade"
                           Closed="MenuPopup_Closed">
                        <Border x:Name="menuPopupBorder" Background="#2A2A2A" CornerRadius="8" Padding="4"
                                BorderBrush="#40FFFFFF" BorderThickness="1">
                            <StackPanel x:Name="menuStack">
                                <Button Style="{StaticResource MenuItemBtn}" Click="About_Click">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="24"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="ℹ" FontWeight="Normal" FontSize="13"
                                                   HorizontalAlignment="Center"/>
                                        <TextBlock Grid.Column="1" Text="Acerca de" FontSize="13"/>
                                    </Grid>
                                </Button>
                                <Button Style="{StaticResource MenuItemBtn}" Click="Settings_Click">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="24"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="⚙" FontWeight="Normal" FontSize="13"
                                                   HorizontalAlignment="Center"/>
                                        <TextBlock Grid.Column="1" Text="Ajustes" FontSize="13"/>
                                    </Grid>
                                </Button>
                                <Button Style="{StaticResource MenuItemBtn}" Click="MenuExit_Click">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="24"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="✕" FontWeight="Normal" FontSize="13"
                                                   HorizontalAlignment="Center"/>
                                        <TextBlock Grid.Column="1" Text="Salir" FontSize="13"/>
                                    </Grid>
                                </Button>
                            </StackPanel>
                        </Border>
                    </Popup>
                    <Grid Grid.Column="1" Width="120"
                          Margin="12,0,12,0"
                          VerticalAlignment="Center" Height="26">
                        <Border x:Name="searchBorder" BorderBrush="#40FFFFFF" BorderThickness="1" CornerRadius="4"
                                Background="Transparent"/>
                        <TextBlock x:Name="searchHint" Text="Búsqueda rápida"
                                   Foreground="#44FFFFFF" FontSize="12"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   IsHitTestVisible="False"
                                   Visibility="Visible"/>
                        <TextBox x:Name="searchBox"
                                 Background="Transparent" BorderThickness="0"
                                 Foreground="#DDDDDD" FontSize="12"
                                 VerticalAlignment="Center"
                                 Padding="8,0,0,0"
                                 CaretBrush="#DDDDDD"
                                 TextChanged="Search_TextChanged"
                                 GotFocus="Search_GotFocus"
                                 LostFocus="Search_LostFocus"/>
                    </Grid>
                    <ToggleButton x:Name="pinBtn" Grid.Column="2"
                                  FontSize="12"
                                  IsChecked="True"
                                  Checked="Topmost_Changed"
                                  Unchecked="Topmost_Changed">
                        <ToggleButton.Style>
                            <Style TargetType="ToggleButton" BasedOn="{StaticResource HeaderBtn}">
                                <Setter Property="Content" Value="📌"/>
                                <Style.Triggers>
                                    <Trigger Property="IsChecked" Value="True">
                                        <Setter Property="Content" Value="📍"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </ToggleButton.Style>
                    </ToggleButton>
                    <Button x:Name="addBtn" Grid.Column="3"
                            Style="{StaticResource HeaderBtn}"
                            FontSize="20" FontWeight="Light"
                            Click="AddNote_Click"
                            Content="+"/>
                    <Popup x:Name="templatePopup" Placement="Bottom"
                           PlacementTarget="{Binding ElementName=addBtn}"
                           StaysOpen="False" AllowsTransparency="True"
                           PopupAnimation="Fade"
                           Closed="TemplatePopup_Closed">
                        <Border x:Name="templatePopupBorder" Background="#2A2A2A" CornerRadius="8" Padding="4"
                                BorderBrush="#40FFFFFF" BorderThickness="1"
                                MinWidth="160" MaxWidth="200">
                            <StackPanel x:Name="templatePanel" />
                        </Border>
                    </Popup>
                    <Button x:Name="minBtn" Grid.Column="4"
                            Style="{StaticResource HeaderBtn}"
                            Click="Minimize_Click"
                            Content="─"/>

                </Grid>
            </Border>

            <!-- Content area: sidebar + notes -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition x:Name="sidebarCol" Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Sidebar -->
                <Border x:Name="sidebarBorder" Grid.Column="0" Background="#232323" Padding="3,6,5,6"
                        MinWidth="48" Width="48">
                    <Grid>
                        <ScrollViewer x:Name="sidebarScroll" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                            <StackPanel>
                                <!-- Toggle button -->
                            <Border x:Name="sidebarToggleBtn" Padding="4" Margin="2,0,2,6"
                                    Style="{StaticResource SidebarItem}"
                                    PreviewMouseDown="SidebarToggle_Click"
                                    MouseEnter="SidebarItem_MouseEnter"
                                    MouseLeave="SidebarItem_MouseLeave">
                                <TextBlock x:Name="sidebarToggleIcon" Text="☰" FontSize="16" Foreground="#BBFFFFFF"
                                           HorizontalAlignment="Center"/>
                            </Border>

                            <!-- Todas las notas -->
                            <Border x:Name="sectAll" Padding="8,8" Margin="2,1"
                                    Style="{StaticResource SidebarItem}"
                                    PreviewMouseDown="SidebarSection_Click"
                                    MouseEnter="SidebarItem_MouseEnter"
                                    MouseLeave="SidebarItem_MouseLeave"
                                    Tag="all">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock x:Name="sectAllIcon" Text="✏️" FontSize="16" VerticalAlignment="Center" Foreground="#BBFFFFFF"/>
                                    <TextBlock x:Name="sectAllLabel" Text=" Todas" FontSize="13"
                                               Foreground="#BBFFFFFF" VerticalAlignment="Center"
                                               Opacity="0"/>
                                    <TextBlock x:Name="sectAllCount" FontSize="10"
                                               Foreground="#88FFFFFF" VerticalAlignment="Center"
                                               Margin="4,0,0,0" Opacity="0"/>
                                </StackPanel>
                            </Border>

                            <!-- Archivadas -->
                            <Border x:Name="sectArchived" Padding="8,8" Margin="2,1"
                                    Style="{StaticResource SidebarItem}"
                                    PreviewMouseDown="SidebarSection_Click"
                                    MouseEnter="SidebarItem_MouseEnter"
                                    MouseLeave="SidebarItem_MouseLeave"
                                    Tag="archived">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock x:Name="sectArchivedIcon" Text="📁" FontSize="16" VerticalAlignment="Center" Foreground="#BBFFFFFF"/>
                                    <TextBlock x:Name="sectArchivedLabel" Text=" Archivadas" FontSize="13"
                                               Foreground="#BBFFFFFF" VerticalAlignment="Center"
                                               Opacity="0"/>
                                    <TextBlock x:Name="sectArchivedCount" FontSize="10"
                                               Foreground="#88FFFFFF" VerticalAlignment="Center"
                                               Margin="4,0,0,0" Opacity="0"/>
                                </StackPanel>
                            </Border>

                            <!-- Papelera -->
                            <Border x:Name="sectTrash" Padding="8,8" Margin="2,1"
                                    Style="{StaticResource SidebarItem}"
                                    PreviewMouseDown="SidebarSection_Click"
                                    MouseEnter="SidebarItem_MouseEnter"
                                    MouseLeave="SidebarItem_MouseLeave"
                                    Tag="trash">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock x:Name="sectTrashIcon" Text="♻️" FontSize="16" VerticalAlignment="Center" Foreground="#BBFFFFFF"/>
                                    <TextBlock x:Name="sectTrashLabel" Text=" Papelera" FontSize="13"
                                               Foreground="#BBFFFFFF" VerticalAlignment="Center"
                                               Opacity="0"/>
                                    <TextBlock x:Name="sectTrashCount" FontSize="10"
                                               Foreground="#88FFFFFF" VerticalAlignment="Center"
                                               Margin="4,0,0,0" Opacity="0"/>
                                </StackPanel>
                            </Border>

                            <!-- Separator -->
                            <Rectangle x:Name="sidebarSepH" Height="1" Fill="#30FFFFFF" Margin="4,6"/>

                            <!-- 📚 Libretas -->
                            <StackPanel>
                                <Border x:Name="sectNotebooksHeader" Padding="8,8" Margin="2,1"
                                        Style="{StaticResource SidebarItem}"
                                        PreviewMouseDown="SidebarAccordion_Click"
                                        MouseEnter="SidebarItem_MouseEnter"
                                        MouseLeave="SidebarItem_MouseLeave"
                                        Tag="notebooks">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock x:Name="sectNotebooksIcon" Text="📚" FontSize="16" VerticalAlignment="Center" Foreground="#BBFFFFFF"/>
                                        <TextBlock x:Name="sectNotebooksLabel" Text=" Libretas" FontSize="13"
                                                   Foreground="#BBFFFFFF" VerticalAlignment="Center"
                                                   Opacity="0"/>
                                        <TextBlock x:Name="sectNotebooksBtnAdd" Text="  +" FontSize="13"
                                                   Foreground="#88FFFFFF" VerticalAlignment="Center"
                                                   Opacity="0" Cursor="Hand"
                                                   PreviewMouseDown="AddNotebook_Click"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                            <!-- 🏷 Tags -->
                            <StackPanel>
                                <Border x:Name="sectTagsHeader" Padding="8,8" Margin="2,1"
                                        Style="{StaticResource SidebarItem}"
                                        PreviewMouseDown="SidebarAccordion_Click"
                                        MouseEnter="SidebarItem_MouseEnter"
                                        MouseLeave="SidebarItem_MouseLeave"
                                        Tag="tags">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock x:Name="sectTagsIcon" Text="🏷" FontSize="16" VerticalAlignment="Center" Foreground="#BBFFFFFF"/>
                                        <TextBlock x:Name="sectTagsLabel" Text=" Tags" FontSize="13"
                                                   Foreground="#BBFFFFFF" VerticalAlignment="Center"
                                                   Opacity="0"/>
                                        <TextBlock x:Name="sectTagsBtnAdd" Text="  +" FontSize="13"
                                                   Foreground="#88FFFFFF" VerticalAlignment="Center"
                                                   Opacity="0" Cursor="Hand"
                                                   PreviewMouseDown="AddTag_Click"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                            <!-- Timeline -->
                            <Border x:Name="sectTimeline" Padding="8,8" Margin="2,1"
                                    Style="{StaticResource SidebarItem}"
                                    PreviewMouseDown="SidebarSection_Click"
                                    MouseEnter="SidebarItem_MouseEnter"
                                    MouseLeave="SidebarItem_MouseLeave"
                                    Tag="timeline">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock x:Name="sectTimelineIcon" Text="🕐" FontSize="16" VerticalAlignment="Center" Foreground="#BBFFFFFF"/>
                                    <TextBlock x:Name="sectTimelineLabel" Text=" Timeline" FontSize="13"
                                               Foreground="#BBFFFFFF" VerticalAlignment="Center"
                                               Opacity="0"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                    <Popup x:Name="sidebarFlyout" AllowsTransparency="True" StaysOpen="True"
                           PopupAnimation="Fade"/>
                    </Grid>
                </Border>

                <!-- Vertical separator -->
                <Rectangle x:Name="sidebarSepV" Grid.Column="0" HorizontalAlignment="Right" Width="1" Fill="#30FFFFFF" IsHitTestVisible="False"/>

                <!-- Notes list (existing) -->
                <ScrollViewer x:Name="scrollViewer" Grid.Column="1"
                              Background="#1E1E1E"
                              VerticalScrollBarVisibility="Visible"
                              CanContentScroll="False"
                              Padding="0,2,0,0">
                    <ItemsControl x:Name="notesList" Margin="0,0,0,0"
                                  PreviewMouseLeftButtonDown="Card_MouseDown"
                                  PreviewMouseMove="Card_MouseMove"
                                  PreviewMouseLeftButtonUp="Card_MouseUp">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <views:NoteCard/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                        <ItemsControl.GroupStyle>
                            <GroupStyle>
                                <GroupStyle.HeaderTemplate>
                                    <DataTemplate>
                                        <Border Padding="14,10,10,4" Margin="0,2,0,0">
                                            <TextBlock Text="{Binding Name, Converter={StaticResource DateGroupConverter}}"
                                                       FontSize="12" FontWeight="SemiBold"
                                                       Foreground="#88FFFFFF"/>
                                        </Border>
                                    </DataTemplate>
                                </GroupStyle.HeaderTemplate>
                            </GroupStyle>
                        </ItemsControl.GroupStyle>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>

            <!-- Status Bar -->
            <Border x:Name="statusBar" Grid.Row="2" Background="#262626" Padding="10,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="statusText" Grid.Column="0"
                               Foreground="#55FFFFFF" FontSize="10"
                               VerticalAlignment="Center"/>
                    <TextBlock x:Name="statsText" Grid.Column="1"
                               Foreground="#44FFFFFF" FontSize="10"
                               VerticalAlignment="Center" Margin="0,0,12,0"/>
                    <TextBlock Grid.Column="2" Foreground="#44FFFFFF" FontSize="10"
                               VerticalAlignment="Center">
                        <Hyperlink x:Name="clearAllLink" NavigateUri=""
                                   Foreground="#55FFFFFF"
                                   Click="ClearAll_Click"
                                   TextDecorations="None">Clear all</Hyperlink>
                    </TextBlock>
                </Grid>
            </Border>
        </Grid>
</Window>
