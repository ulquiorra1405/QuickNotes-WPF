<Window x:Class="QuickNotes.ZenWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        ShowInTaskbar="False"
        ShowActivated="False"
        Topmost="False"
        ResizeMode="NoResize"
        Background="Transparent"
        Width="100" Height="100">
    <!-- 
      This WPF window with AllowsTransparency=True creates a WS_EX_LAYERED window.
      The background is fully transparent, so the DWM backdrop below it shows through.
      Dark tint overlay on top for the frosted look.
    -->
    <Grid>
        <!-- Dark tint overlay: adjusts the frosted glass darkness -->
        <Rectangle Name="TintOverlay" Fill="#80000000" />
    </Grid>
</Window>
