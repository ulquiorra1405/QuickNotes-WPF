<Window x:Class="QuickNotes.ZenWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="False"
        ShowInTaskbar="False"
        Topmost="False"
        ResizeMode="NoResize"
        Background="#1E1E1E">
    <Grid>
        <!-- Dark tint overlay: blends with DWM backdrop to create frosted look -->
        <Rectangle Name="TintOverlay" Fill="#88000000" />
    </Grid>
</Window>
