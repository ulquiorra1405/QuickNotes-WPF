<Window x:Class="QuickNotes.ZenWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        ShowActivated="False"
        Topmost="False"
        ResizeMode="NoResize"
        Width="100" Height="100">

    <Border x:Name="RootBorder">
        <!-- Tint overlay: semi-transparent dark on top of the system blur -->
        <Rectangle x:Name="TintOverlay" Fill="#80000000" />
    </Border>
</Window>
